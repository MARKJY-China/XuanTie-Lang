// Test/23_弱引用归零验证.xt
// P0：弱引用核心行为——局部变量归零 + 类成员归零

示("--- 23_弱引用归零验证 开始 ---")

// 1. 局部变量弱引用归零
设 强 = "临时对象"
弱 设 弱观察 = 强
示("1.局部释放前: #{弱观察}")
强 = "新对象"
示("1.局部归零: #{弱观察 == 空}")

// 2. 类成员弱引用归零——核心验证
型 父23 {
    设 名称
    函 造(n) { 此.名称 = n }
}
型 子23 {
    弱 设 父23: 父23?
    函 造(p) {
        此.父23 = p
    }
}

设 p2 = 造 父23("根节点")
设 c2 = 造 子23(p2)
// 用嵌套访问读父名（不保留中间引用，避免额外retain阻止释放）
示("2.释放前父名: " & c2.父23.名称)
p2 = 空
// 关键验证：覆盖唯一强引用后，类成员弱引用自动归零
示("2.类成员归零: #{c2.父23 == 空}")

// 3. 弱引用不影响ARC——独立对象释放验证
设 独立 = 造 父23("独立节点")
弱 设 弱指向 = 独立
示("3.独立释放前: #{弱指向 != 空}")
独立 = 空
示("3.独立归零: #{弱指向 == 空}")

示("--- 23_弱引用归零验证 结束 ---")
