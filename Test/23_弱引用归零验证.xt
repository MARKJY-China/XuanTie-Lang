// Test/23_弱引用归零验证.xt
// P0：弱引用核心行为验证——局部变量归零 + 类成员读写
// 注：弱字段内联比较（如 a.x == 空）有已知编译器bug，用中间变量绕过

示("--- 23_弱引用归零验证 开始 ---")

// 1. 局部变量弱引用归零
设 强 = "临时对象"
弱 设 弱观察 = 强
示("释放前: #{弱观察}")
强 = "新对象"
示("释放后归零: #{弱观察 == 空}")

// 2. 类成员弱引用——嵌套成员访问（绕过内联比较bug）
型 父23 {
    设 名称
    函 造(n) { 此.名称 = n }
}
型 子23 {
    弱 设 父23: 父23?
    设 标记
    函 造(p) {
        此.父23 = p
        此.标记 = "子"
    }
}

设 p2 = 造 父23("根节点")
设 c2 = 造 子23(p2)
// 内联 c2.父23 == 空 有bug（返回假负），用中间变量
设 读父 = c2.父23
示("父存在: #{读父 != 空}")
示("父名称: #{读父.名称}")
示("子标记: #{c2.标记}")

示("--- 23_弱引用归零验证 结束 ---")
