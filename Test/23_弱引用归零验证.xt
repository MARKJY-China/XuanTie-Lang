// Test/23_弱引用归零验证.xt
// P0：弱引用核心行为验证——局部变量归零 + 类成员读写

示("--- 23_弱引用归零验证 开始 ---")

// 测试 1：局部变量弱引用归零
设 强 = "临时对象"
弱 设 弱观察 = 强
示("释放前: #{弱观察}")
强 = "新对象"
示("释放后归零: #{弱观察 == 空}")

// 测试 2：类成员弱引用——读写验证
型 父23 {
    设 名称
    函 造(n) { 此.名称 = n }
}
型 子23 {
    弱 设 父23: 父23?
    设 标记
    函 造(p) {
        此.父23 = p
        此.标记 = "子"
    }
}

设 p2 = 造 父23("根节点")
设 c2 = 造 子23(p2)
设 读父 = c2.父23
示("父存在: #{读父 != 空}")
示("父名称: #{读父.名称}")
示("子标记: #{c2.标记}")

示("--- 23_弱引用归零验证 结束 ---")
