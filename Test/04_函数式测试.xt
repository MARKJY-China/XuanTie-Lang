// Test/04_函数式测试.xt
// 测试高阶函数、匿名函数、Lambda 风格调用

示("--- 04_函数式测试 开始 ---")

// 1. 匿名函数 (Lambda)
设 加法 = 函(a, b) { 返 a + b }
示("1 + 2 = #{加法(1, 2)}")

// 2. 高阶函数 (作为参数)
函 执行二次(f, x) {
    返 f(f(x))
}
设 翻倍 = 函(n) { 返 n * 2 }
示("2 翻倍两次: #{执行二次(翻倍, 2)}") // 预期 8

// 3. 高阶函数 (作为返回值)
函 创建累加器(初始) {
    设 累计 = 初始
    返 函(增量) {
        累计 = 累计 + 增量
        返 累计
    }
}
设 累加 = 创建累加器(10)
示("累加 5: #{累加(5)}") // 预期 15
示("累加 10: #{累加(10)}") // 预期 25

// 4. 模拟 Map 操作
函 映射列表(列表, 变换) {
    设 x结果 = []
    遍历 项 于 列表 {
        x结果.追加(变换(项))
    }
    返 x结果
}
设 数字 = [1, 2, 3]
设 平方 = 映射列表(数字, 函(n) { 返 n * n })
示("平方映射结果: #{平方}")

示("--- 04_函数式测试 结束 ---")
