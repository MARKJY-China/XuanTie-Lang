// test_v0120_features.xt

示("=== 结果容器增强测试 ===")
设 r1 = 整("123")
示("成功解包: " & r1.解包())
示("成功或: " & r1.或(0))

设 r2 = 整("abc")
示("失败或默认: " & r2.或(999))
// 示("失败解包测试 (应报错): " & r2.解包())

设 r3 = r1.映射(函(x) { 返 x * 2 })
示("映射后值: " & r3.解包())

设 r4 = r2.复原(函(e) { 返 0 })
示("复原后值: " & r4.解包())

示("\n=== 数组增强测试 ===")
设 列表 = [3, 1, 4, 1, 5, 9]
示("包含 2: " & 列表.包含(2))
示("包含 5: " & 列表.包含(5))
示("去重后: " & 列表.去重())
示("排序后: " & 列表.排序())
设 归纳和 = 列表.归纳(函(累, x) { 返 累 + x }, 0)
示("归纳求和: " & 归纳和)
设 嵌套 = [[1, 2], [3, 4]]
示("展平后: " & 嵌套.展平())

示("\n=== 字典增强测试 ===")
设 d = {"a": 1, "b": 2}
示("大小: " & d.大小)
设 合并后 = d.合并({"c": 3})
示("合并后大小: " & 合并后.大小)

示("\n=== 字符串增强测试 ===")
设 串 = "  Hello XuanTie  "
示("大写: " & 串.大写)
示("小写: " & 串.小写)
示("开头是 '  Hello': " & 串.开头是("  Hello"))
示("结尾是 'Tie  ': " & 串.结尾是("Tie  "))

示("\n=== 数学增强测试 ===")
示("PI: " & 数学.PI)
示("取整(3.7): " & 数学.取整(3.7))
示("进一(3.1): " & 数学.进一(3.1))
示("四舍五入(3.5): " & 数学.四舍五入(3.5))
示("2的10次方: " & 数学.幂(2, 10))

示("\n=== 路径测试 ===")
示("合并路径: " & 路径.合并("usr", "local", "bin"))
