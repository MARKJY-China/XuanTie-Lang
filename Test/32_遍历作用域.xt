// Test/32_遍历作用域.xt
示("--- 32_遍历作用域 ---")

// 测试1: 外层遍历变量，内层当访问
遍历 项 于 [1, 2] {
    设 k = 0
    当 k < 1 {
        示("测试1: 项=#{项} k=#{k}")
        k = k + 1
    }
}

// 测试2: 外层设变量，内层遍历访问
设 列表 = [10, 20]
设 外部 = "hello"
遍历 项2 于 列表 {
    遍历 子项 于 [1] {
        示("测试2: 外部=#{外部} 项2=#{项2} 子项=#{子项}")
    }
}

// 测试3: 外层遍历变量，内层遍历中访问
遍历 a 于 [100] {
    遍历 b 于 [200] {
        示("测试3: a=#{a} b=#{b}")
    }
}

示("--- 结束 ---")
