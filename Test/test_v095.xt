示("--- v0.9.5 类型系统深耕测试 ---")

// 1. 联合类型测试 (Union Types)
示("\n1. 联合类型测试:")
设 混合值: 字 | 整 = "我是字符串"
示("混合值(字): " & 混合值)

混合值 = 123
示("混合值(整): " & 混合值)

尝试 {
    混合值 = 3.14 // 期望 字 或 整，得到 小数
} 捕捉 (错误) {
    示("捕获到联合类型错误: " & 错误)
}

// 2. 可空类型测试 (Nullable Types)
示("\n2. 可空类型测试:")
设 可空名字: 字? = "玄铁"
示("可空名字: " & 可空名字)

可空名字 = 空
示("可空名字(设为空): " & 可空名字)

尝试 {
    设 必须有值: 字 = 空 // 不带 ? 的类型不能为 空
} 捕捉 (错误) {
    示("捕获到空值类型错误: " & 错误)
}

// 3. 联合类型与可空组合
示("\n3. 复杂组合测试:")
设 复杂变量: 整 | 数组? = [1, 2, 3]
示("复杂变量(数组): " & 复杂变量)

复杂变量 = 999
示("复杂变量(整): " & 复杂变量)

复杂变量 = 空
示("复杂变量(空): " & 复杂变量)

// 4. 函数参数与返回值的联合类型
示("\n4. 函数类型校验测试:")
设 智能打印 = 函(内容: 字 | 数组) {
    示("智能打印内容: " & 内容)
}

智能打印("文本内容")
智能打印(["数组", "内容"])

尝试 {
    智能打印(123)
} 捕捉 (错误) {
    示("捕获到函数参数类型错误: " & 错误)
}

设 转换 = 函(输入: 字): 字 | 整 {
    若 输入 == "一" { 返 1 }
    返 输入
}

示("转换('一'): " & 转换("一"))
示("转换('文本'): " & 转换("文本"))

示("\n测试完成！")
