示("--- v0.9.6 接口与位置感知综合测试 ---")

// 1. 接口测试
口 形状 {
    函 面积(): 小数
}

型 圆形 {
    设 半径 = 0.0
    函 造(r: 小数) {
        半径 = r
    }
    函 面积(): 小数 {
        返 3.14 * 半径 * 半径
    }
}

型 矩形 {
    设 宽 = 0.0
    设 高 = 0.0
    函 造(w: 小数, h: 小数) {
        宽 = w
        高 = h
    }
    函 面积(): 小数 {
        返 宽 * 高
    }
}

函 计算总面积(s1: 形状, s2: 形状): 小数 {
    返 s1.面积() + s2.面积()
}

设 c = 造 圆形(10.0)
设 r = 造 矩形(5.0, 20.0)

示("总面积: " & 计算总面积(c, r))

// 2. 堆栈追踪测试
函 触发错误() {
    示("准备触发错误...")
    内部逻辑()
}

函 内部逻辑() {
    设 a = 10
    设 b = 0
    返 a / b
}

尝试 {
    触发错误()
} 捕捉 (错误) {
    示("\n成功捕获深度错误：")
    示(错误)
}

示("\n测试完成！")
