// 字符串索引测试
打印("--- 字符串索引测试 ---")
变量 文本 = "玄铁XuanTie"
打印("原文: " & 文本)
打印("第一个字符: " & 文本[0])
打印("第五个字符: " & 文本[4])
打印("最后一个字符: " & 文本[8])

// 数组索引测试
打印("\n--- 数组索引测试 ---")
变量 列表 = [10, 20, 30]
打印("列表[1]: " & 列表[1])

// 字典索引测试
打印("\n--- 字典索引测试 ---")
变量 映射 = {"键": "值", "1": "数字键"}
打印("映射['键']: " & 映射["键"])
打印("映射[1]: " & 映射[1])
