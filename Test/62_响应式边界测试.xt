// Test 62 — @响应 边界与嵌套场景
// 验证：响应变量在循环、闭包、型定义中的行为

示("=== Test 62: @响应边界 ===")

// 1. 循环中修改响应变量
@响应 设 累加 = 0
设 i = 0
当 i < 5 {
    累加 = 累加 + i
    i = i + 1
}
若 累加 == 10 { 示("PASS: 循环累加") } 否 { 示("FAIL: 循环累加=" & 累加.转字()) }

// 2. 遍历中修改
@响应 设 和 = 0
遍历 n 于 [1, 2, 3] {
    和 = 和 + n
}
若 和 == 6 { 示("PASS: 遍历修改") } 否 { 示("FAIL: 遍历=" & 和.转字()) }

// 3. 若分支中修改
@响应 设 状态 = 0
若 状态 == 0 {
    状态 = 1
} 否 {
    状态 = 0
}
若 状态 == 1 { 示("PASS: 条件分支修改") } 否 { 示("FAIL: 条件分支") }

// 4. 响应变量默认值为空
@响应 设 未初始化
若 未初始化 == 空 { 示("PASS: 响应默认空") } 否 { 示("FAIL: 默认空") }

// 5. 闭包捕获响应变量（顶层）
@响应 设 闭包计数 = 0
设 闭包 = 函() {
    闭包计数 = 闭包计数 + 1
}
闭包()
闭包()
若 闭包计数 == 2 { 示("PASS: 闭包捕获响应变量") } 否 { 示("FAIL: 闭包=" & 闭包计数.转字()) }

// 6. 型定义中的响应字段
型 界面状态 {
    @响应 设 标题
    函 造(t) { 此.标题 = t }
}
设 界面 = 造 界面状态("首页")
若 界面.标题 == "首页" { 示("PASS: 型字段响应") } 否 { 示("FAIL: 型字段") }
界面.标题 = "设置"
若 界面.标题 == "设置" { 示("PASS: 型字段修改") } 否 { 示("FAIL: 型字段修改") }

// 7. 多个@响应连续声明
@响应 设 x = 0
@响应 设 y = 0
@响应 设 z = 0
x = 1 ; y = 2 ; z = 3
若 x + y + z == 6 { 示("PASS: 连续响应声明") } 否 { 示("FAIL: 连续") }

示("=== Test 62 完成 ===")
