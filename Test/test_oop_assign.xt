型 点 {
    设 x = 0
    私 设 y = 0
    
    设 设置Y = 函(新值) {
        y = 新值
    }
    
    设 获取Y = 函() {
        返 y
    }
}

设 p = 造 点{"x": 10, "y": 20}
示("初始 x: " & p.x)
p.x = 100
示("修改后 x: " & p.x)

尝试 {
    示("尝试读取私有 y: " & p.y)
} 捕捉 (错误) {
    示("捕获错误: " & 错误)
}

尝试 {
    p.y = 500
} 捕捉 (错误) {
    示("捕获错误: " & 错误)
}

p.设置Y(888)
示("通过方法获取 y: " & p.获取Y())
