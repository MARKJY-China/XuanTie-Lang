// test_v0112_fixes.xt
示("--- v0.11.2 实战补全测试 ---")

// 1. 字符串插值测试
设 名字 = "玄铁"
设 版本 = "0.11.2"
示("插值测试：欢迎使用 " & 名字 & "，当前版本是 " & 版本 & "！")
示("计算测试：1 + 2 = " & (1 + 2))

// 2. 类型转换测试
设 s = "100"
设 结果1 = 整(s)
若 结果1.成功 {
    设 n = 结果1.值
    设 f = 小数(n)
    示("转换测试: 字 '" & s & "' -> 整 " & n & " -> 小数 " & f)
    示("类型: " & 字(n))
}

// 3. 数学库扩展测试
示("数学.幂次(2, 10) = ${数学.幂次(2, 10)}")
示("数学.向上取整(3.1) = ${数学.向上取整(3.1)}")
示("数学.向下取整(3.9) = ${数学.向下取整(3.9)}")
示("数学.最大值(10, 20) = ${数学.最大值(10, 20)}")

// 4. 字典操作测试
设 库 = {"名": "玄铁", "岁": 1}
示("字典键: " & 库.键())
示("字典值: " & 库.值())
若 库.含("名") {
    示("包含 '名' 键")
}
库.删("岁")
示("删除后: " & 库)

// 5. 类与 '此' 关键字测试
型 战士 {
    设 名字
    设 生命 = 100
    
    函 造(n) { 此.名字 = n }
    函 攻击() { 示(此.名字 & " 发起攻击！") }
}
设 我 = 造 战士("关羽")
我.攻击()

// 6. 字符串方法统一调用测试
设 原串 = "  你好,玄铁  "
示("修剪前长度: " & 字符串.长度(原串))
示("修剪后: '" & 原串.修剪() & "'")
示("替换测试: " & 原串.替换("玄铁", "世界").修剪())

// 7. 文件句柄测试
设 结果2 = 文件.开("README.md")
若 结果2.成功 {
    示("成功打开文件")
}

示("测试完成！")
