// Test/24_循环引用检测.xt
// W401：编译器检测两个类型互相强引用并输出警告

示("--- 24_循环引用检测 开始 ---")

// 场景A：应触发 W401——两个类型互相直接强引用
型 员工A {
    设 经理: 经理A    // 强引用经理
}
型 经理A {
    设 下属: 员工A    // 强引用员工 → 循环！
}

// 场景B：不应触发——一方用弱引用打破了循环
型 员工B {
    弱 设 经理: 经理B?   // 弱引用，不形成循环
}
型 经理B {
    设 下属: 员工B       // 强引用，但另一方是弱引用→无循环
}

示("--- 24_循环引用检测 结束 ---")
