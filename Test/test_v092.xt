示("--- v0.9.2 字节处理与系统参数测试 ---")

// 1. 测试字节处理
示("\n1. 测试字节处理:")
设 文本 = "玄铁XuanTie"
设 字节数据 = 字节.从字(文本)
示("原始文本: " & 文本)
示("字节数据: " & 字节数据)
示("字节长度: " & 字节数据.长度)
示("第一个字节 (X): " & 字节数据[0]) // 注意："玄" 是多字节，第一个字节是 E7

设 还原文本 = 字节.到字(字节数据)
示("还原文本: " & 还原文本)

// 2. 测试系统参数
示("\n2. 测试系统参数:")
示("所有参数: " & 系统.参数)
示("当前程序: " & 系统.参数[0])
若 系统.参数.长度 > 1 {
    示("第一个参数: " & 系统.参数[1])
} 否 {
    示("提示：运行此脚本时可以带上参数测试，例如: xuantie Test/test_v092.xt 哈哈")
}
