// Test/01_基础测试.xt
// 测试基础算术、位运算、逻辑运算以及类型推导

示("--- 01_基础测试 开始 ---")

//基础算术运算测试
设 a: 整 = 10 //显式类型(整数)声明变量(a)并赋值(10)
设 b: 整 = 20 //同上
设 c = a + b //声明变量(c)并赋值(a+b=30)
示("10 + 20 = #{c}") // 预期 30

设 d = b - a //声明变量(d)并赋值(b-a=10)
示("20 - 10 = #{d}") // 应输出: "20 - 10 = 10"

设 e = a * 3
示("10 * 3 = #{e}") // 预期 30

设 f = b / 4
示("20 / 4 = #{f}") // 预期 5

// 位运算测试
设 g = 1 位与 3
示("1 位与 3 = #{g}") // 预期 1

设 h = 1 位或 2
示("1 位或 2 = #{h}") // 预期 3

设 i = 1 左移 2
示("1 左移 2 = #{i}") // 预期 4

// 逻辑运算测试
设 j = 真 //显式类型(布尔值)声明变量(j)并赋值(真)
设 k = 假 //同上
若 j 且 非 k { //如果 j 是真且 k 是假
    示("逻辑运算测试通过")
} 否 {
    示("逻辑运算测试通过")
} 否 {
    示("逻辑运算测试失败")
}

// 4. 类型推导验证
设 推导整 = 100
设 推导字 = "hello"
示("推导整类型验证: #{推导整}")
示("推导字类型验证: #{推导字}")

示("--- 01_基础测试 结束 ---")
