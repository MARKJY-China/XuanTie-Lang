// Test/16_控制流测试.xt
// 测试遍历循环中的 续 和 断 控制流，以及嵌套遍历的正确作用域隔离

示("--- 16_控制流测试 开始 ---")

// ============================================
// 1. 续 在遍历中——跳过奇数 (不用%运算符)
// ============================================
设 数集 = [1, 2, 3, 4, 5]
设 偶数和 = 0
遍历 数 于 数集 {
    设 是奇 = 0
    若 数 == 1 { 是奇 = 1 }
    若 数 == 3 { 是奇 = 1 }
    若 数 == 5 { 是奇 = 1 }
    若 是奇 == 1 { 续 }
    偶数和 = 偶数和 + 数
}
示("偶数和: #{偶数和}")  // 预期: 2+4 = 6

// ============================================
// 2. 断 在遍历中——找到3后停止
// ============================================
设 找到值 = 0
遍历 数 于 数集 {
    若 数 >= 3 {
        找到值 = 数
        断
    }
}
示("首个大值: #{找到值}")  // 预期: 3

// ============================================
// 3. 嵌套遍历 + 断 只影响最内层循环
// ============================================
设 矩阵 = [[1,2,3],[4,5,6],[7,8,9]]
设 行计数 = 0
设 首大 = 0
遍历 行 于 矩阵 {
    行计数 = 行计数 + 1
    设 子集 = [4, 5, 6]
    遍历 元素 于 子集 {
        若 元素 > 5 {
            首大 = 元素
            断  // 只跳出内层，外层继续
        }
    }
}
示("行计数: #{行计数}, 首大: #{首大}")  // 预期: 行计数=3, 首大=6

// ============================================
// 4. 嵌套遍历 + 续 只影响最内层
// ============================================
设 总计数 = 0
设 跳计数 = 0
遍历 行 于 矩阵 {
    设 子集2 = [4, 5, 6, 7, 8]
    遍历 数 于 子集2 {
        若 数 < 6 { 跳计数 = 跳计数 + 1 ; 续 }
        总计数 = 总计数 + 1
    }
}
示("总计数: #{总计数}, 跳计数: #{跳计数}")  // 预期: 总计数=9, 跳计数=6

// ============================================
// 5. 当循环内嵌套遍历——断在遍历内
// ============================================
设 大数集 = [11, 12, 13, 14, 15]
设 阶段和 = 0
设 i = 0
当 i < 2 {
    设 阶段计 = 0
    遍历 数 于 大数集 {
        若 数 > 13 { 断 }
        阶段计 = 阶段计 + 数
    }
    阶段和 = 阶段和 + 阶段计
    i = i + 1
}
示("阶段和: #{阶段和}")  // 预期: 两轮各 11+12+13=36, 合计 72

示("--- 16_控制流测试 结束 ---")
