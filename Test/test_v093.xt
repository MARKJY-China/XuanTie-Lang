示("--- v0.9.3 工业级数组操作测试 ---")

设 列表 = [1, 2, 3]
示("初始列表: " & 列表)
示("初始长度: " & 列表.长度)

// 1. 追加 (Append)
列表.追加(4, 5)
示("\n1. 追加(4, 5)后: " & 列表)
示("当前长度: " & 列表.长度)

// 2. 截取 (Slice)
设 子列表 = 列表.截取(1, 4)
示("\n2. 截取(1, 4)结果: " & 子列表)
示("原列表未变: " & 列表)

// 3. 删 (Remove)
列表.删(2) // 删除索引为 2 的元素 (即 3)
示("\n3. 删(索引2)后: " & 列表)

// 4. 插 (Insert)
列表.插(1, "新元素")
示("\n4. 插(索引1, '新元素')后: " & 列表)

// 5. 找 (IndexOf)
设 位置 = 列表.找("新元素")
示("\n5. 找 '新元素' 的位置: " & 位置)
示("找 999 的位置: " & 列表.找(999))

// 6. 映射 (Map)
设 数字列表 = [1, 2, 3, 4]
设 平方列表 = 数字列表.映射(函(x, i) { 返 x * x })
示("\n6. 映射 [1,2,3,4] -> x*x: " & 平方列表)

// 7. 过滤 (Filter)
设 偶数列表 = 数字列表.过滤(函(x, i) { 返 x % 2 == 0 })
示("\n7. 过滤 [1,2,3,4] -> 偶数: " & 偶数列表)

// 8. 链式调用
设 链式结果 = [1, 2, 3, 4, 5]
    .过滤(函(x) { 返 x > 2 })
    .映射(函(x) { 返 x * 10 })
    .追加(99)
示("\n8. 链式调用结果: " & 链式结果)
