// Test/02_字符串测试.xt
// 测试字符串拼接、插值、字节操作与内置方法

示("--- 02_字符串测试 开始 ---")

// 1. 基础拼接
设 s1 = "玄"
设 s2 = "铁"
设 s3 = s1 & s2
示("拼接结果: #{s3}") // 预期 "玄铁"

// 2. 字符串插值 (多层嵌套)
设 年份 = 2024
设 状态 = "自举中"
设 插值 = "当前年份: #{年份}, 状态: #{状态}"
示(插值)

// 3. 字节与字符
设 文本 = "Hello 玄铁"
示("字节数: #{文本.字节数}")
示("字符数: #{文本.字符数}")
示("第一个字节: #{文本.字节(0)}")

// 4. 字符串方法
设 原始 = "  abc def  "
// 注意：根据 runtime/xt_runtime.h，可能有这些方法，这里模拟测试
示("是否包含 'abc': #{文本.包含?('玄铁')}")

// 5. 转义字符
设 转义 = "第一行\n第二行\t缩进 \"引号\""
示("转义测试: ")
示(转义)

示("--- 02_字符串测试 结束 ---")
