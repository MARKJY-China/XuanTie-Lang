// Test/67_无栈状态机全覆盖.xt
// 无栈状态机全愿景标准示例——涵盖多等待、嵌套、通道、选择等全部模式
//
// 状态：此文件为规范/蓝图。标记 "MVP" 的测试当前可编译运行；
//       标记 "P2" 的测试依赖多等待（Phase 3）；
//       标记 "P3" 的测试依赖通道选择（Phase 4）。
//
// 编译（当前仅 MVP 部分可通过）：玄铁.exe tie Test/67_无栈状态机全覆盖.xt

示("=== 67_无栈状态机全覆盖 开始 ===")

// ================================================================
// 第一部分：MVP — 单等待（当前可用）
// ================================================================
示("--- [MVP] 单等待基础 ---")

// [MVP] 异步块内一个等待，且等待为最后语句
设 _mvp_inner = 异步 { 时.睡(100); 示("  MVP内部完成") }
设 _mvp_outer = 异步 {
    示("  MVP外部开始等待")
    等待(_mvp_inner)
}
等待(_mvp_outer)
// 预期输出顺序：
//   MVP外部开始等待
//   MVP内部完成
//   (outer 状态机恢复→DONE→main 继续)
示("PASS: MVP单等待")

// ================================================================
// 第二部分：P2 — 多等待（编译异步 需支持多状态编号）
// ================================================================
示("--- [P2] 多等待 ---")

// [P2] 异步块内两个等待，代码在等待之间和之后继续执行
// 预期输出顺序：
//   步骤1开始
//   任务A完成
//   步骤2开始（在第一个等待恢复后执行）
//   任务B完成
//   全部步骤完成
设 _p2_任务A = 异步 { 时.睡(100); 示("  任务A完成") }
设 _p2_任务B = 异步 { 时.睡(200); 示("  任务B完成") }

// [预期] 以下代码当前编译失败（含等标记可检测到等待，但编译异步仅生成 s0/s1 两态）
