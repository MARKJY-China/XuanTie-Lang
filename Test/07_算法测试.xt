// Test/07_算法测试.xt
// 测试递归算法性能与逻辑 (以斐波那契和阶乘为例)

示("--- 07_算法测试 开始 ---")

// 1. 递归斐波那契
函 斐波那契(n: 整): 整 {
    若 n <= 1 { 返 n }
    返 斐波那契(n - 1) + 斐波那契(n - 2)
}

设 开始 = 时.微秒()
设 x结果 = 斐波那契(30)
设 耗时 = 时.微秒() - 开始
示("斐波那契(30) = #{x结果}, 耗时: #{耗时} 微秒")

// 2. 尾递归优化测试 (如果编译器支持)
函 阶乘(n, 累计) {
    若 n <= 1 { 返 累计 }
    返 阶乘(n - 1, n * 累计)
}
示("阶乘(10) = #{阶乘(10, 1)}")

// 3. 循环版本对比
函 斐波那契循环(n) {
    若 n <= 1 { 返 n }
    设 a = 0
    设 b = 1
    设 i = 2
    当 i <= n {
        设 临时 = a + b
        a = b
        b = 临时
        i = i + 1
    }
    返 b
}
示("循环版 斐波那契(20) = #{斐波那契循环(20)}")

示("--- 07_算法测试 结束 ---")
