// Test 64 — FlexBox 布局核心算法验证
// 纯算术测试, 不依赖渲染库

示("=== Test 64: FlexBox 布局算法 ===")

// 1. 文本尺寸估算
设 字号 = 16
设 文本宽 = 2 * 字号 * 3
设 文本高 = 字号 * 7 / 5
若 文本宽 == 96 { 示("PASS: 文本固有宽") } 否 { 示("FAIL: 文本宽=" & 文本宽.转字()) }
若 文本高 == 22 { 示("PASS: 文本固有高") } 否 { 示("FAIL: 文本高=" & 文本高.转字()) }

// 2. 固定尺寸行布局: 两个子元素
设 子1宽 = 96 ; 设 子2宽 = 96
设 行宽 = 子1宽 + 子2宽
若 行宽 == 192 { 示("PASS: 行布局总宽") } 否 { 示("FAIL: 总宽=" & 行宽.转字()) }

// 3. 弹性布局: flex-grow 分配剩余空间
设 可用宽 = 200
设 固定宽 = 80
设 剩余 = 可用宽 - 固定宽
若 剩余 == 120 { 示("PASS: 剩余空间") } 否 { 示("FAIL: 剩余=" & 剩余.转字()) }

设 弹值 = 1 ; 设 总弹 = 1
设 弹尺寸 = 固定宽 + 剩余 * 弹值 / 总弹
若 弹尺寸 == 200 { 示("PASS: 弹性扩展") } 否 { 示("FAIL: 弹=" & 弹尺寸.转字()) }

// 4. 多弹性: 两个 flex=1 的子元素平分剩余
设 子A固有 = 50 ; 设 子B固有 = 50
设 总固有 = 子A固有 + 子B固有
设 弹余 = 可用宽 - 总固有
设 子A后 = 子A固有 + 弹余 * 1 / 2
设 子B后 = 子B固有 + 弹余 * 1 / 2
若 子A后 == 100 且 子B后 == 100 { 示("PASS: 多弹性平分") } 否 { 示("FAIL: A=" & 子A后.转字() & " B=" & 子B后.转字()) }

// 5. space-between: 两个元素
设 间间隙 = 剩余 / 1
若 间间隙 == 120 { 示("PASS: space-between") } 否 { 示("FAIL: 间=" & 间间隙.转字()) }

// 6. space-around: 每个元素前后有半间隙
设 均间隙 = 120 / 2
设 均偏移 = 均间隙 / 2
若 均间隙 == 60 且 均偏移 == 30 { 示("PASS: space-around") } 否 { 示("FAIL: 均=" & 均间隙.转字() & " 偏=" & 均偏移.转字()) }

// 7. center 对齐
设 中对齐 = 120 / 2
若 中对齐 == 60 { 示("PASS: 居中对齐偏移") } 否 { 示("FAIL: 中=" & 中对齐.转字()) }

// 8. end 对齐
设 末偏移 = 120
若 末偏移 == 120 { 示("PASS: 末尾对齐偏移") } 否 { 示("FAIL: 末=" & 末偏移.转字()) }

// 9. 间距计算: 3个子元素, gap=10
设 间距值 = 10 ; 设 子数 = 3
设 总间距 = 间距值 * (子数 - 1)
若 总间距 == 20 { 示("PASS: 间距总计") } 否 { 示("FAIL: 间距=" & 总间距.转字()) }

// 10. 列布局高度求和
设 行1高 = 50 ; 设 行2高 = 50
设 列总高 = 行1高 + 行2高
若 列总高 == 100 { 示("PASS: 列布局高度") } 否 { 示("FAIL: 列=" & 列总高.转字()) }

// 11. 交叉轴 stretch: 子填满父容器叉轴空间
设 父叉轴 = 300
设 子原高 = 22
设 子撑高 = 父叉轴  // stretch 效果
若 子撑高 == 300 { 示("PASS: stretch 撑满") } 否 { 示("FAIL: 撑=" & 子撑高.转字()) }

// 12. 外边距与内边距
设 外距左 = 5 ; 设 外距右 = 5
设 内距左 = 10 ; 设 内距右 = 10
设 内容可用 = 400 - 外距左 - 外距右 - 内距左 - 内距右
若 内容可用 == 370 { 示("PASS: 边距缩减") } 否 { 示("FAIL: 内容=" & 内容可用.转字()) }

示("=== Test 64 完成 ===")
