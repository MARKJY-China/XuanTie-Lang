打印("--- 数组遍历测试 ---")
变量 列表 = [1, 2, 3, 4, 5]
遍历 元素 于 列表 {
    如果 元素 == 3 {
        继续
    }
    如果 元素 == 5 {
        跳出
    }
    打印(元素)
}

打印("--- 字典遍历测试 ---")
变量 映射 = {"a": 1, "b": 2}
遍历 键 于 映射 {
    打印(键)
}

打印("--- 字符串遍历测试 ---")
变量 文本 = "玄铁"
遍历 字符 于 文本 {
    打印(字符)
}

打印("--- 当循环中的跳出/继续测试 ---")
变量 i = 0
当 i < 5 {
    i = i + 1
    如果 i == 2 {
        继续
    }
    如果 i == 4 {
        跳出
    }
    打印(i)
}
