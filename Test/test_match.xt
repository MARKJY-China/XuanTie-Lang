// test_match.xt
示("--- 模式匹配测试 ---")

函 测试匹配(值) {
    匹配 值 {
        1 -> { 示("${值} 匹配到了数字 1") }
        "123" -> { 示("${值} 匹配到了字符串 123") }
        是 整 -> { 示("${值} 匹配到了整数类型") }
        是 字 -> { 示("${值} 匹配到了字符串类型") }
        _ -> { 示("${值} 进入了默认分支") }
    }
}

测试匹配(1)
测试匹配("123")
测试匹配(100)
测试匹配("你好")
测试匹配(真)
