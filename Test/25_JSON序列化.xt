// Test/25_JSON序列化.xt
// JSON 序列化（化）与基础反序列化（解）
// 注：解当前为简化实现，仅支持字符串/数字/布尔/空的基础类型反序列化，不支持{}和[]

示("--- 25_JSON序列化 开始 ---")

// 1. 字典序列化
设 d = {"名": "玄铁", "版": 18, "稳定": 真}
设 j = 化(d)
示("字典序列化: " & j)

// 2. 数组序列化
设 arr = [1, 2, 3]
设 ja = 化(arr)
示("数组序列化: " & ja)

// 3. 基础反序列化——字符串
设 s1 = 解("\"玄铁\"")
示("解字符串: " & s1)

// 4. 基础反序列化——整数
设 n1 = 解("12345")
示("解整数: #{n1}")

// 5. 基础反序列化——布尔
设 b1 = 解("true")
示("解布尔: #{b1}")

示("--- 25_JSON序列化 结束 ---")

