// Test/27_嵌套当测试.xt
示("--- 27_嵌套当测试 开始 ---")

// 测试1: 函数作用域变量在当体内重赋值
设 i = 0
设 j = 0
当 i < 3 {
    j = 0
    当 j < 2 {
        示("嵌套当: i=#{i} j=#{j}")
        j = j + 1
    }
    i = i + 1
}

// 测试2: 简单冒泡
设 列表 = [3, 1, 2]
设 n = 列表.长度
示("排序前[0]=#{列表[0]}, [1]=#{列表[1]}, [2]=#{列表[2]}")
设 a = 0
设 b = 0
设 t = 空
当 a < n {
    b = 0
    当 b < n - a - 1 {
        若 列表[b] > 列表[b+1] {
            t = 列表[b]
            列表[b] = 列表[b+1]
            列表[b+1] = t
        }
        b = b + 1
    }
    a = a + 1
}
示("排序后[0]=#{列表[0]}, [1]=#{列表[1]}, [2]=#{列表[2]}")

// 测试3: 去重
设 源 = [1, 2, 2, 3]
设 输出 = []
设 x = 0
设 len = 源.长度
设 y = 0
设 项 = 空
设 已存在 = 假
设 outLen = 0
当 x < len {
    项 = 源[x]
    已存在 = 假
    y = 0
    outLen = 输出.长度
    当 y < outLen {
        若 输出[y] == 项 { 已存在 = 真 ; 断 }
        y = y + 1
    }
    若 非 已存在 { 输出.追加(项) }
    x = x + 1
}
示("去重长度: #{输出.长度}")

示("--- 27_嵌套当测试 结束 ---")
