// Test/18_字符串方法.xt
// 字符串内置方法测试：截取、分割、替换、包含?

示("--- 18_字符串方法 开始 ---")

// 1. 截取
设 s = "Hello 玄铁世界"
示("截取(0,5): " & s.截取(0, 5))      // Hello
示("截取(6,8): " & s.截取(6, 11))     // 玄铁（UTF-8字节索引）

// 2. 替换
设 s2 = s.替换("玄铁", "XuanTie")
示("替换后: " & s2)

// 3. 分割
设 部分 = s.分割(" ")
示("分割结果长度: #{部分.长度}")
示("分割[0]: #{部分[0]}")

// 4. 包含?
示("包含'Hello': #{s.包含?("Hello")}")
示("包含'XYZ': #{s.包含?("XYZ")}")

示("--- 18_字符串方法 结束 ---")
