// Test/13_闭包测试.xt
// 测试闭包的环境捕获与持久化状态

示("--- 13_闭包测试 开始 ---")

// 1. 基础环境捕获
设 外部变量 = "外部"
设 闭包1 = 函() {
    示("闭包捕获了: #{外部变量}")
}
闭包1()

// 2. 状态持久化 (计数器)
函 创建计数器() {
    设 计 = 0
    返 函() {
        计 = 计 + 1
        返 计
    }
}

设 计数 = 创建计数器()
示("第一次: #{计数()}") // 1
示("第二次: #{计数()}") // 2
示("第三次: #{计数()}") // 3
示("第四次: #{计数()}") // 3
示("第五次: #{计数()}") // 3

// 3. 多个独立闭包
设 计数A = 创建计数器()
设 计数B = 创建计数器()
示("计数A: #{计数A()}") // 1
示("计数A: #{计数A()}") // 2
示("计数B: #{计数B()}") // 1 (独立环境)

// 4. 捕获并修改外部变量 (引用捕获)
设 x = 100
设 修改者 = 函(新值) {
    x = 新值
}
修改者(200)
示("x 被修改为: #{x}") // 预期 200

示("--- 13_闭包测试 结束 ---")
