// Test/12_泛型测试.xt
// 测试类泛型与函数泛型的定义与实例化

示("--- 12_泛型测试 开始 ---")

// 1. 泛型类定义 (Box<T>)
型 盒子<T> {
    设 内容: T
    函 造(初始内容: T) {
        此.内容 = 初始内容
    }
    函 获取() : T {
        返 此.内容
    }
}

// 2. 实例化泛型类
设 整盒 = 造 盒子<整>(123)
示("整盒内容: #{整盒.获取()}")

设 字盒 = 造 盒子<字>("玄铁")
示("字盒内容: #{字盒.获取()}")

// 3. 泛型函数
函 交换<T>(a: T, b: T) {
    // 玄铁目前可能通过数组返回或解构支持交换
    返 [b, a]
}

设 结果 = 交换<整>(10, 20)
示("交换结果: #{结果}")

示("--- 12_泛型测试 结束 ---")
