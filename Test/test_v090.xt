示("--- v0.9.0 网络与系统原语测试 ---")

// 1. 测试 HTTP 客户端 (求)
示("\n1. 测试 HTTP 请求 (求):")
设 网页 = 求("http://www.baidu.com")
网页.接着(函(内容) {
    示("获取成功，长度: " & 内容.长度)
}).否则(函(错) {
    示("获取失败: " & 错)
})

// 2. 测试 系统命令执行 (执)
示("\n2. 测试系统执行 (执):")
设 路径 = 执("cmd /c echo %cd%")
路径.接着(函(内容) {
    示("当前工作目录: " & 内容)
})

// 3. 测试 通道 (道)
示("\n3. 测试通道通讯 (道):")
设 消息道 = 道
异步 {
    时.睡(500)
    消息道.送("来自异步任务的消息")
}
示("正在等待通道消息...")
设 收到 = 消息道.收()
示("收到: " & 收到)

// 4. 测试 HTTP 服务端 (听)
示("\n4. 测试 HTTP 服务端 (听):")
听(8080, 函(请, 答) {
    示("服务端收到请求: " & 请["路径"])
    答.写("你好，玄铁 HTTP")
})

时.睡(200)
求("http://127.0.0.1:8080/test").接着(函(内容) {
    示("客户端收到回复: " & 内容)
})

// 5. 测试 TCP 服务端 (听) 与 客户端 (连)
示("\n5. 测试 Socket 通讯 (听/连):")
听(9999, 函(管道) {
    异步 {
        设 收到 = 管道.读()
        示("TCP 服务端收到: " & 收到)
        管道.写("你好，我是 TCP 服务端")
        管道.关()
    }
})

时.睡(100)

连("127.0.0.1:9999").接着(函(管道) {
    管道.写("你好，我是 TCP 客户端")
    设 回复 = 管道.读()
    示("TCP 客户端收到回复: " & 回复)
    管道.关()
})

// 延迟一下等待异步任务完成
时.睡(1000)
