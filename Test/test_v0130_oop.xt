// test_v0130_oop.xt

型 动物 {
    函 叫() { 示("动物叫") }
}

型 猫 承 动物 {
    覆 函 叫() { 示("喵喵喵~") }
}

示("--- OOP 契约测试 ---")
设 m = 造 猫()
m.叫()

// 运算符重载测试
型 向量 {
    设 x
    设 y
    函 造(x, y) {
        此.x = x
        此.y = y
        示("初始化向量: " & 此.x & ", " & 此.y)
    }
    
    函 _加_(另) {
        返 造 向量(此.x + 另.x, 此.y + 另.y)
    }
}

设 v1 = 造 向量(1, 2)
设 v2 = 造 向量(3, 4)
设 v3 = v1 + v2
示("向量相加结果: x=" & v3.x & ", y=" & v3.y)

示("\n--- 结构化错误测试 ---")
尝试 {
    1 / 0
} 捕捉 (错) {
    示("捕获错误消息: " & 错.消息)
}

测试 "基础数学断言" {
    系统.断言(1 + 1 == 2, "数学崩坏了")
}

/// 这是一个带文档注释的函数
/// 用于演示文档提取功能
函 演示文档() {
    返 真
}

示("\n文档提取模拟 (String 表达):")
示(演示文档)
