示("--- v0.9.9 模块化命名空间测试 ---")

// 1. 显式命名空间引用
引 "./lib.xt" 予 库

示("引用库的名字: " & 库.名字)
库.招呼("开发者")

// 2. 测试私有成员隔离
尝试 {
    示("尝试访问秘密: " & 库.秘密)
} 捕捉 (错误) {
    示("捕获到预期错误 (私有成员不可见): " & 错误)
}

// 3. 测试导出类
设 计 = 造 库.计数器()
计.增()
计.增()
示("计数器当前值: " & 计.值)

// 4. 匿名引用 (向后兼容模式)
引 "./lib.xt" // 不带 予 别名，会返回导出字典

示("\n测试完成！")
