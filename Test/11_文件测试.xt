// Test/11_文件测试.xt
// 测试外部函数声明 (FFI) 与文件系统交互

示("--- 11_文件测试 开始 ---")

// 1. 声明外部 C 函数 (假设 runtime 提供这些)
外 函 printf(格式: 字, 参数: 整): 整
// 外 函 xt_file_read(路径: 字): 结果 // 已在标准库中注册，取消注释避免重复
// 外 函 xt_file_write(路径: 字, 内容: 字): 结果

// 2. 文件写入测试
设 目标路径 = "test_temp.txt"
设 写入结果 = 文件.写(目标路径, "玄铁自举编译器单元测试数据")
若 写入结果.成功 {
    示("文件写入成功: #{目标路径}")
}

// 3. 文件读取测试
设 读取结果 = 文件.读(目标路径)
若 读取结果.成功 {
    示("文件读取内容: #{读取结果.值}")
}

// 4. 检查文件是否存在
若 文件.存在?(目标路径) {
    示("验证: 文件确实存在")
}

// 5. 格式化输出 (通过 FFI printf)
printf("FFI printf 测试: 整数=%d\n", 2024)

示("--- 11_文件测试 结束 ---")
