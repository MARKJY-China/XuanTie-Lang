// test_v0131_stdlib.xt

示("--- v0.13.1 标准库增强测试 ---")

// 1. 字符串增强测试
设 s = "  Hello XuanTie  "
示("原始字符串: '" & s & "'")
示("修剪后: '" & s.修剪() & "'")
示("修剪开头: '" & s.修剪开头() & "'")
示("修剪结尾: '" & s.修剪结尾() & "'")

设 s2 = "abcabc"
示("s2: " & s2)
示("s2 索引 'b': " & s2.索引("b"))
示("s2 最后索引 'b': " & s2.最后索引("b"))
示("s2 重复 3 次: " & s2.重复(3))
示("s2 包含? 'ca': " & s2.包含?("ca"))
示("s2 是否为空? " & s2.空?)

设 emptyStr = ""
示("空字符串是否为空? " & emptyStr.空?)

// 2. 集合增强测试
设 arr = [1, 2, 3]
示("数组: " & arr)
示("数组包含? 2: " & arr.包含?(2))
示("数组是否非空? " & arr.非空?)

设 dict = {"a": 1, "b": 2}
示("字典: " & dict)
示("字典含? 'a': " & dict.含?("a"))
示("字典是否为空? " & dict.空?)

// 3. 数学库增强测试
示("数学.最大值(1, 5, 2): " & 数学.最大值(1, 5, 2))
示("数学.最小值(10, -1, 3.5): " & 数学.最小值(10, -1, 3.5))
示("数学.随机(10): " & 数学.随机(10))

// 4. 字符串模块测试
示("字符串.连接('A', 'B', 'C'): " & 字符串.连接("A", "B", "C"))
设 bytes = 字节.从字("Hello")
示("从字节恢复字符串: " & 字符串.来自字节(bytes))

示("\n测试完成！")
