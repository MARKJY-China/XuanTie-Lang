// Test/05_OOP基础测试.xt
// 测试类的定义、实例化、构造函数与属性访问

示("--- 05_OOP基础测试 开始 ---")

型 坐标 {
    设 x
    设 y
    
    函 造(x参, y参) {
        此.x = x参
        此.y = y参
        示(" -> [系统] 坐标实例已创建: (#{此.x}, #{此.y})")
    }
    
    函 获取距离() {
        // 简单模拟欧几里得距离的平方
        返 此.x * 此.x + 此.y * 此.y
    }
    
    函 移动(dx, dy) {
        此.x = 此.x + dx
        此.y = 此.y + dy
    }
}

// 1. 实例化
设 p1 = 造 坐标(10, 20)

// 2. 属性访问
示("当前坐标: (#{p1.x}, #{p1.y})")

// 3. 方法调用
设 距离 = p1.获取距离()
示("距离原点平方: #{距离}")

// 4. 修改状态
p1.移动(5, -5)
示("移动后坐标: (#{p1.x}, #{p1.y})")

// 5. 多个实例
设 p2 = 造 坐标(0, 0)
示("p2 坐标: (#{p2.x}, #{p2.y})")

示("--- 05_OOP基础测试 结束 ---")
