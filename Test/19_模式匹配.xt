// Test/19_模式匹配.xt
// 模式匹配测试：值匹配、通配符、类型匹配

示("--- 19_模式匹配 开始 ---")

// 1. 精确值匹配
设 x = 42
匹配 x {
    42 -> { 示("精确匹配: 42") }
    100 -> { 示("错误：不该匹配100") }
    _ -> { 示("错误：应命中42") }
}

// 2. 通配符默认分支
设 y = 999
匹配 y {
    1 -> { 示("错误：不该匹配1") }
    _ -> { 示("通配符匹配: 默认分支") }
}

// 3. 字符串类型匹配
设 z = "玄铁"
匹配 z {
    是 字 -> { 示("类型匹配: 字符串") }
    _ -> { 示("错误：应匹配字符串类型") }
}

// 4. 匹配在函数内返回值
函 匹配测试(v) {
    匹配 v {
        42 -> { 返 "四十二" }
        _ -> { 返 "其他" }
    }
    返 "未知"
}
示("函数内匹配: " & 匹配测试(42))
示("函数内匹配默认: " & 匹配测试(99))

示("--- 19_模式匹配 结束 ---")
