// Test/09_通道测试.xt
// 测试并发通道 (Channel) 的数据发送与接收

示("--- 09_通道测试 开始 ---")

// 1. 创建通道
设 x道 = 道(2) // 容量为 2

// 2. 异步生产者
异步 {
    示(" -> [生产者] 正在发送数据 1...")
    x道.发(1)
    示(" -> [生产者] 正在发送数据 2...")
    x道.发(2)
    示(" -> [生产者] 发送完毕")
}

// 3. 主线程消费者
示("[消费者] 准备接收数据...")
设 x数据1 = x道.收()
示("[消费者] 收到数据: #{x数据1}")
设 x数据2 = x道.收()
示("[消费者] 收到数据: #{x数据2}")

// 4. 阻塞测试
异步 {
    时.睡(300)
    x道.发("延迟消息")
}
示("[消费者] 正在等待延迟消息...")
示("[消费者] 收到: #{x道.收()}")

示("--- 09_通道测试 结束 ---")
