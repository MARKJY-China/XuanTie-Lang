示("--- v0.11.5 迭代特性验证 ---")

// 1. 类型转换统一返回结果
设 s = "123"
设 n_res = 整(s)
若 n_res.成功 {
    示("整成功: " & n_res.值)
}

设 f_res = 小数("3.14")
若 f_res.成功 {
    示("小数成功: " & f_res.值)
}

设 e_res = 整("abc")
若 非 e_res.成功 {
    示("整失败(预期): " & e_res.错误)
}

// 2. 字典解构遍历
设 映射 = {"名": "玄铁", "岁": 1, "主": "MARK"}
示("字典内容:")
遍历 键, 值 于 映射 {
    示("  - " & 键 & ": " & 值)
}

// 3. 数组带索引遍历
设 列表 = ["A", "B", "C"]
示("数组带索引遍历:")
遍历 索引, 值 于 列表 {
    示("  [" & 索引 & "] = " & 值)
}

// 4. 字符串修剪
设 脏串 = "   你好 玄铁   "
示("修剪前: |" & 脏串 & "|")
示("修剪后: |" & 脏串.修剪() & "|")

示("测试完成！")
