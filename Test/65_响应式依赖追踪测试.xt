// Test 65 — View = f(State) 响应式依赖追踪
// 验证: 状态读取追踪、变化通知、自动标脏

示("=== Test 65: 响应式依赖追踪 ===")

// ============================================================
// 内联响应式原语（模拟 UI.态取/态设/造状态）
// ============================================================

设 _栈 = []

函 造状态(数据) {
    设 容器 = {}
    容器["_值"] = 数据
    容器["_监听"] = {}
    容器["_脏"] = 假
    容器["_依赖"] = {}
    返 容器
}

函 态取(状态, 键) {
    若 状态 == 空 { 返 空 }
    若 _栈.长度 > 0 {
        设 上下文 = _栈[_栈.长度 - 1]
        上下文["_依赖"][键] = 真
    }
    若 状态["_值"].含?(键) { 返 状态["_值"][键] }
    返 空
}

函 态设(状态, 键, 新值) {
    若 状态 == 空 { 返 空 }
    设 旧值 = 空
    若 状态["_值"].含?(键) { 旧值 = 状态["_值"][键] }
    若 旧值 == 新值 { 返 空 }
    状态["_值"][键] = 新值
    若 状态["_监听"].含?(键) {
        遍历 cb 于 状态["_监听"][键] {
            若 cb != 空 { cb() }
        }
    }
    状态["_脏"] = 真
}

函 进上下文(状态) {
    设 上下文 = {}
    上下文["_依赖"] = {}
    _栈.追加(上下文)
    状态["_依赖"] = {}
    状态["_脏"] = 假
    返 上下文
}

函 退上下文() {
    若 _栈.长度 > 0 {
        设 新栈 = []
        设 i = 0
        当 i < _栈.长度 - 1 {
            新栈.追加(_栈[i])
            i = i + 1
        }
        _栈 = 新栈
    }
}

// ============================================================
// Test 1: 基础读写
// ============================================================
设 s1 = 造状态({"姓名":"张三", "年龄":25})
若 态取(s1, "姓名") == "张三" 且 态取(s1, "年龄") == 25 {
    示("PASS: 基础读写")
} 否 { 示("FAIL: 基础读写") }

// ============================================================
// Test 2: 写入触发标脏
// ============================================================
设 s2 = 造状态({"计数":0})
态设(s2, "计数", 42)
若 s2["_脏"] == 真 且 态取(s2, "计数") == 42 {
    示("PASS: 写入标脏")
} 否 { 示("FAIL: 写入标脏") }

// ============================================================
// Test 3: 同值写入不触发
// ============================================================
设 s3 = 造状态({"计数":5})
态设(s3, "计数", 5)
设 脏前 = s3["_脏"]
若 脏前 == 假 { 示("PASS: 同值不触发") } 否 { 示("FAIL: 同值") }

// ============================================================
// Test 4: 渲染上下文追踪依赖
// ============================================================
设 s4 = 造状态({"a":1, "b":2, "c":3})
设 ctx4 = 进上下文(s4)
态取(s4, "a")
态取(s4, "c")
退上下文()
若 ctx4["_依赖"].含?("a") 且 ctx4["_依赖"].含?("c") 且 非 ctx4["_依赖"].含?("b") {
    示("PASS: 依赖追踪")
} 否 { 示("FAIL: 依赖追踪") }

// ============================================================
// Test 5: 状态变化触发订阅回调
// ============================================================
设 s5 = 造状态({"值":0})
设 回调计数5 = 0
s5["_监听"]["值"] = []
s5["_监听"]["值"].追加(函() { 回调计数5 = 回调计数5 + 1 })
态设(s5, "值", 10)
若 回调计数5 == 1 { 示("PASS: 订阅回调") } 否 { 示("FAIL: 回调数=" & 回调计数5.转字()) }

// ============================================================
// Test 6: 多次变化多次回调
// ============================================================
设 s6 = 造状态({"计数":0})
设 回调计6 = 0
s6["_监听"]["计数"] = []
s6["_监听"]["计数"].追加(函() { 回调计6 = 回调计6 + 1 })
态设(s6, "计数", 1)
态设(s6, "计数", 2)
态设(s6, "计数", 3)
若 回调计6 == 3 { 示("PASS: 多次回调") } 否 { 示("FAIL: 回调=" & 回调计6.转字()) }

// ============================================================
// Test 7: 多个订阅者
// ============================================================
设 s7 = 造状态({"标志":假})
设 通知1 = 0 ; 设 通知2 = 0
s7["_监听"]["标志"] = []
s7["_监听"]["标志"].追加(函() { 通知1 = 1 })
s7["_监听"]["标志"].追加(函() { 通知2 = 2 })
态设(s7, "标志", 真)
若 通知1 == 1 且 通知2 == 2 { 示("PASS: 多订阅者") } 否 { 示("FAIL: n1=" & 通知1.转字() & " n2=" & 通知2.转字()) }

// ============================================================
// Test 8: 状态快照
// ============================================================
设 s8 = 造状态({"x":10, "y":20})
设 快照 = s8["_值"]
若 快照["x"] == 10 且 快照["y"] == 20 {
    示("PASS: 状态快照")
} 否 { 示("FAIL: 快照") }

// ============================================================
// Test 9: 标脏→清除→验证 完整流程
// ============================================================
设 s9 = 造状态({"文本":"初始"})

设 ctx9 = 进上下文(s9)
设 文本9 = 态取(s9, "文本")
退上下文()

态设(s9, "文本", "修改后")
若 s9["_脏"] == 真 { 示("PASS: 渲染后标脏") } 否 { 示("FAIL: 未标脏") }

// 手动标脏清除后验证状态
设 s9b = 造状态({"文本":"第二次"})
设 ctx9b = 进上下文(s9b)
设 文本9b = 态取(s9b, "文本")
退上下文()

态设(s9b, "文本", "修改第二次")
若 文本9b == "第二次" 且 s9b["_脏"] == 真 {
    示("PASS: 独立状态渲染周期")
} 否 { 示("FAIL: s9b") }

// ============================================================
// Test 10: 嵌套渲染上下文
// ============================================================
设 s10 = 造状态({"外层":"A", "内层":"B"})

设 ctx外 = 进上下文(s10)
态取(s10, "外层")

设 ctx内 = 进上下文(s10)
态取(s10, "内层")
退上下文()

退上下文()

若 ctx外["_依赖"].含?("外层") 且 ctx内["_依赖"].含?("内层") {
    示("PASS: 嵌套上下文")
} 否 { 示("FAIL: 嵌套") }

示("=== Test 65 完成 ===")
