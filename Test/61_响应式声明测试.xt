// Test 61 — @响应 修饰符基础测试
// 验证：@响应 设 语法解析、编译、赋值、读取

示("=== Test 61: @响应声明 ===")

// 1. 基础声明与赋值
@响应 设 计数 = 0
若 计数 == 0 { 示("PASS: 响应声明初值") } 否 { 示("FAIL: 初值=" & 计数.转字()) }

// 2. 重新赋值
计数 = 10
若 计数 == 10 { 示("PASS: 响应变量重赋值") } 否 { 示("FAIL: 重赋值=" & 计数.转字()) }

// 3. 算术运算
@响应 设 总分 = 0
总分 = 总分 + 5
总分 = 总分 + 10
若 总分 == 15 { 示("PASS: 响应变量累加") } 否 { 示("FAIL: 累加=" & 总分.转字()) }

// 4. 在函数内使用
函 递增() {
    计数 = 计数 + 1
}
递增()
递增()
若 计数 == 12 { 示("PASS: 函数内修改响应变量") } 否 { 示("FAIL: 函数内修改=" & 计数.转字()) }

// 5. 条件判断中使用
@响应 设 开关 = 真
若 开关 { 示("PASS: 响应布尔真") } 否 { 示("FAIL: 响应布尔") }
开关 = 假
若 非 开关 { 示("PASS: 响应布尔假") } 否 { 示("FAIL: 响应布尔翻转") }

// 6. 字符串响应变量
@响应 设 标题 = "初始"
若 标题 == "初始" { 示("PASS: 响应字符串初值") } 否 { 示("FAIL: 响应字符串") }
标题 = "修改后"
若 标题 == "修改后" { 示("PASS: 响应字符串修改") } 否 { 示("FAIL: 响应字符串修改=" & 标题) }

// 7. 多个响应变量并存
@响应 设 a = 1
@响应 设 b = 2
@响应 设 c = a + b
若 c == 3 { 示("PASS: 多响应变量") } 否 { 示("FAIL: 多响应=" & c.转字()) }

// 8. 与非响应变量混合
设 普通 = 100
@响应 设 响应 = 50
若 响应 == 50 且 普通 == 100 { 示("PASS: 响应与非响应混合") } 否 { 示("FAIL: 混合") }

示("=== Test 61 完成 ===")
