示("--- v0.9.4 可选类型注解测试 ---")

// 1. 变量类型注解
设 名字: 字 = "玄铁"
示("名字: " & 名字)

尝试 {
    设 错误数字: 字 = 123
} 捕捉 (错误) {
    示("捕获到预期错误: " & 错误)
}

// 2. 函数参数类型注解
设 加法 = 函(a: 整, b: 整): 整 {
    返 a + b
}

示("1 + 2 = " & 加法(1, 2))

尝试 {
    示("尝试传入字符串: " & 加法("1", 2))
} 捕捉 (错误) {
    示("捕获到参数错误: " & 错误)
}

// 3. 函数返回值类型注解
设 坏函数 = 函(): 字 {
    返 123 // 期望返回字，实际返回整
}

尝试 {
    示("执行坏函数...")
    坏函数()
} 捕捉 (错误) {
    示("捕获到返回值错误: " & 错误)
}

// 4. 自定义类作为类型
型 节点 {
    设 值 = 0
}

设 树: 节点 = 造 节点()
示("树的值: " & 树.值)

尝试 {
    设 伪造树: 节点 = "我不是树"
} 捕捉 (错误) {
    示("捕获到类类型错误: " & 错误)
}

// 5. 继承关系校验
型 基类 {}
型 子类 承 基类 {}

设 对象: 基类 = 造 子类()
示("子类对象赋值给基类变量: 成功")

尝试 {
    设 错误对象: 子类 = 造 基类()
} 捕捉 (错误) {
    示("捕获到非子类错误: " & 错误)
}

示("\n测试完成！")
