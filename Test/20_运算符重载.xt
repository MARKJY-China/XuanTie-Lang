// Test/20_运算符重载.xt
// 运算符重载测试：_加_、_等_

示("--- 20_运算符重载 开始 ---")

// 1. 定义支持加法的向量类
型 向量 {
    设 x
    设 y
    函 造(a, b) {
        此.x = a
        此.y = b
    }
    函 _加_(其他) {
        返 造 向量(此.x + 其他.x, 此.y + 其他.y)
    }
    函 _等_(其他) {
        返 此.x == 其他.x 且 此.y == 其他.y
    }
}

// 2. 加法测试
设 v1 = 造 向量(1, 2)
设 v2 = 造 向量(3, 4)
设 v3 = v1 + v2
示("向量加法: (#{v3.x}, #{v3.y})")

// 3. 相等测试
设 v4 = 造 向量(4, 6)
示("v3 == v4: #{v3 == v4}")
示("v1 == v2: #{v1 == v2}")

示("--- 20_运算符重载 结束 ---")
