// Test/17_弱引用测试.xt
// 弱引用功能测试——核心验证：打破循环引用，对象释放时自动清零

示("--- 17_弱引用测试 开始 ---")

// 第一个测试点：基本弱引用声明和读取   
设 强引用 = "Hello 弱引用"
弱 设 弱引用 = 强引用
示("强引用: #{强引用}")
示("弱引用: #{弱引用}")

// 第二个测试点：带类型注解的弱引用 
弱 设 可选弱引用 = 强引用
示("类型注解弱引用: #{可选弱引用}")

// 第三个测试点：初始化为空的弱引用
弱 设 空弱引用 = 空
示("空弱引用值: #{空弱引用}")

// 第四个测试点：弱引用变量重新赋值 
设 新对象 = "另一个对象"
弱引用 = 新对象
示("弱引用重赋值后: #{弱引用}")

// 第五个测试点：核心测试——强引用释放后弱引用自动置空
示("--- 核心：弱引用归零测试 ---")
设 临时对象 = "短暂存在的对象"
弱 设 观察者 = 临时对象
示("释放前，观察者看到: #{观察者}")
临时对象 = "新的对象"
示("覆盖强引用后，观察者看到: #{观察者}")
// 预期：观察者 = 空

// 第六个测试点：类成员弱引用——打破循环引用
示("--- 类成员弱引用：循环引用测试 ---")
型 父节点 {
    设 名称
    设 子列表
    函 造(n) {
        此.名称 = n
        此.子列表 = []
    }
}

型 子节点 {
    弱 设 父: 父节点?
    设 名称
    函 造(p, n) {
        此.父 = p
        此.名称 = n
    }
}

设 p = 造 父节点("根")
设 c = 造 子节点(p, "叶子")
p.子列表.追加(c)
示("子节点引用父: #{c.父.名称}")
// 注：p 和 c 不会形成循环引用——c.父 是弱引用

示("--- 17_弱引用测试 结束 ---")
