// Test/21_泛型可空组合.xt
// 泛型多参数 + 可空修饰符组合测试

示("--- 21_泛型可空组合 开始 ---")

// 1. 泛型多参数 <K, V>
型 键值对<K, V> {
    设 键名: K
    设 键值: V
    函 造(k: K, v: V) {
        此.键名 = k
        此.键值 = v
    }
}

设 kv = 造 键值对<字, 整>("版本", 18)
示("键值对: #{kv.键名} = #{kv.键值}")

// 2. 泛型 + 可空类型：字典 value 可空
型 缓存<K, V> {
    设 数据: 字典<K, V?>
    函 造() {
        此.数据 = {}
    }
    函 存(k: K, v: V) {
        此.数据[k] = v
    }
    函 取(k: K): V? {
        若 此.数据.包含?(k) {
            返 此.数据[k]
        }
        返 空
    }
}

设 c = 造 缓存<字, 整>()
c.存("点击数", 100)
示("缓存命中: #{c.取("点击数")}")
示("缓存未命中: #{c.取("不存在")}")

// 3. 数组元素可空
设 混合列表 = ["存在", 空, "也存在"]
示("混合列表长度: #{混合列表.长度}")
示("混合列表[0]: #{混合列表[0]}")
示("混合列表[1]: #{混合列表[1]}")

示("--- 21_泛型可空组合 结束 ---")
