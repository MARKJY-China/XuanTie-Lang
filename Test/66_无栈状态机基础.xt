// Test/66_无栈状态机基础.xt
// 测试无栈状态机 MVP：异步块内含单个等待（等待须为块末语句）
// 编译：玄铁.exe tie Test/66_无栈状态机基础.xt

示("=== 66_无栈状态机基础 开始 ===")

// ----------------------------------------------------------
// 测试1: 基础单等待——等待为异步体最后一条语句
示("[测试1] 基础单等待")
设 x内部任务 = 异步 { 时.睡(200); 示("  -> 内部任务完成") }
设 x状态机任务 = 异步 {
    示("  -> 状态机开始，等待内部任务...")
    等待(x内部任务)
}
等待(x状态机任务)
示("PASS: 测试1 完成")

// ----------------------------------------------------------
// 测试2: 多个状态机任务并发执行
示("[测试2] 多状态机并发")
设 x任务A = 异步 { 时.睡(300); 示("  -> 任务A完成") }
设 x任务B = 异步 { 时.睡(150); 示("  -> 任务B完成") }

设 x状态机1 = 异步 {
    示("  -> 状态机1 等待任务A")
    等待(x任务A)
}
设 x状态机2 = 异步 {
    示("  -> 状态机2 等待任务B")
    等待(x任务B)
}

等待(x状态机2)
等待(x状态机1)
示("PASS: 测试2 完成")

// ----------------------------------------------------------
// 测试3: 状态机捕获外部变量
示("[测试3] 状态机捕获外部变量")
设 x计数器 = 0
设 x增量任务 = 异步 { 时.睡(100); x计数器 = x计数器 + 100 }

设 x捕获状态机 = 异步 {
    示("  -> 状态机捕获 x计数器=" & x计数器)
    等待(x增量任务)
}
等待(x捕获状态机)
示("  等待后 x计数器=" & x计数器)

若 x计数器 == 100 {
    示("PASS: 测试3 完成")
} 否 {
    示("FAIL: x计数器=" & x计数器 & "，预期100")
}

// ----------------------------------------------------------
// 测试4: 无等待异步块不受状态机影响（回归验证）
示("[测试4] 无等待异步块")
设 x普通异步 = 异步 {
    时.睡(100)
    示("  -> 普通异步块执行")
}
等待(x普通异步)
示("PASS: 测试4 完成")

// ----------------------------------------------------------
// 测试5: 状态机任务 ID 独立不冲突
示("[测试5] 状态机ID独立")
设 x任务列表 = []
设 x索引数组 = [0, 1, 2, 3, 4]
遍历 i 于 x索引数组 {
    设 x内 = 异步 { 时.睡(50) }
    设 x外 = 异步 {
        等待(x内)
    }
    x任务列表.追加(x外)
}
遍历 _t 于 x任务列表 {
    等待(_t)
}
示("PASS: 测试5 完成")

// ----------------------------------------------------------
// 测试6: 等待任务的结果传递（当前 MVP 无返回值，仅验证不崩溃）
示("[测试6] 等待结果传递")
设 x结果任务 = 异步 { 时.睡(100) }
设 x结果状态机 = 异步 {
    等待(x结果任务)
}
设 x结果 = 等待(x结果状态机)
示("PASS: 测试6 完成（结果=" & x结果 & "）")

示("=== 66_无栈状态机基础 结束 ===")
