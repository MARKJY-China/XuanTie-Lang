示("--- v0.9.7 泛型 (Generics) 测试 ---")

// 1. 泛型类定义
型 盒子<T> {
    设 值: T
    函 造(v: T) {
        值 = v
    }
    函 获取(): T {
        返 值
    }
}

// 2. 泛型类实例化
设 数字盒子: 盒子<整> = 造 盒子<整>(123)
示("数字盒子值: " & 数字盒子.获取())

设 文本盒子: 盒子<字> = 造 盒子<字>("玄铁")
示("文本盒子值: " & 文本盒子.获取())

尝试 {
    设 错误盒子: 盒子<整> = 造 盒子<字>("还是文本")
} 捕捉 (错误) {
    示("捕获到泛型实例化错误: " & 错误)
}

// 3. 泛型函数
函 恒等<T>(x: T): T {
    返 x
}

示("恒等<整>(100): " & 恒等<整>(100))
示("恒等<字>('你好'): " & 恒等<字>("你好"))

尝试 {
    恒等<整>("我不是数字")
} 捕捉 (错误) {
    示("捕获到泛型函数参数错误: " & 错误)
}

// 4. 复杂泛型：联合类型与泛型
型 结果容器<T, E> {
    设 数据: T | E
    函 造(d: T | E) {
        数据 = d
    }
}

设 成功结果: 结果容器<整, 字> = 造 结果容器<整, 字>(200)
设 失败结果: 结果容器<整, 字> = 造 结果容器<整, 字>("找不到页面")

示("成功结果数据: " & 成功结果.数据)
示("失败结果数据: " & 失败结果.数据)

示("\n测试完成！")
