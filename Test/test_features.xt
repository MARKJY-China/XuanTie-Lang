常 π:小数 = 3.14
打印("圆周率: " & π)
设 半径 = 5
打印("面积: " & π * 半径 * 半径)

// 1. Result 类型与链式调用测试
设 获取数据 = 函(成功与否) {
    若 成功与否 {
        返 成功("核心数据")
    } 否 {
        返 失败("网络超时")
    }
}

打印("--- 链式调用测试 ---")
获取数据(真)
    .接着(函(内容) {
        打印("获取成功: " & 内容)
        返 成功(内容 & " 已处理")
    })
    .否则(函(错) {
        打印("不应该运行到这里")
    })

获取数据(假)
    .接着(函(内容) {
        打印("不应该运行到这里")
    })
    .否则(函(错) {
        打印("捕获到错误: " & 错)
    })

// 2. Try/Catch 测试
打印("\n--- Try/Catch 测试 ---")
尝试 {
    打印("尝试执行一些可能报错的代码...")
    // 故意触发运行时错误
    设 x = 0
    设 a = 10 / x
} 捕捉 (错误信息) {
    打印("捕捉到异常: " & 错误信息)
}

// 3. 异步与并行测试
打印("\n--- 异步与并发测试 ---")
设 耗时任务 = 函(名) {
    打印("开始任务: " & 名)
    返 名 & " 完成"
}

设 任务1 = 异步 { 耗时任务("任务A") }
打印("主线程继续运行...")
设 结果1 = 等待(任务1)
打印("等待结果: " & 结果1)

打印("\n--- 并行测试 ---")
设 并行结果 = 并行 {
    { 耗时任务("并行1") },
    { 耗时任务("并行2") },
    { 耗时任务("并行3") }
}
打印("所有并行任务结果: ")
打印(并行结果)
