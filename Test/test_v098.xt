示("--- v0.9.8 泛型约束 (Generic Constraints) 测试 ---")

// 1. 定义接口约束
口 会飞的 {
    函 飞行()
}

口 会叫的 {
    函 叫()
}

// 2. 定义实现类
型 鸟 {
    函 飞行() { 示("鸟在飞...") }
    函 叫() { 示("咕咕...") }
}

型 飞机 {
    函 飞行() { 示("飞机在飞...") }
}

// 3. 定义受约束的泛型函数
函 启动飞行<T 承 会飞的>(器物: T) {
    器物.飞行()
}

示("测试 启动飞行<鸟>:")
启动飞行<鸟>(造 鸟())

示("\n测试 启动飞行<飞机>:")
启动飞行<飞机>(造 飞机())

尝试 {
    示("\n测试非法调用 启动飞行<整>:")
    启动飞行<整>(123)
} 捕捉 (错误) {
    示("捕获到约束错误: " & 错误)
}

// 4. 多个泛型参数与约束
函 协同<T 承 会飞的, U 承 会叫的>(飞行器: T, 鸣叫器: U) {
    飞行器.飞行()
    鸣叫器.叫()
}

示("\n测试多约束 协同<飞机, 鸟>:")
协同<飞机, 鸟>(造 飞机(), 造 鸟())

// 5. 泛型类约束
型 实验室<T 承 会叫的> {
    设 研究对象: T
    函 造(对象: T) {
        研究对象 = 对象
    }
    函 听声音() {
        研究对象.叫()
    }
}

设 鸟类实验室 = 造 实验室<鸟>(造 鸟())
示("\n测试泛型类约束 实验室<鸟>:")
鸟类实验室.听声音()

尝试 {
    示("\n测试非法实例化 实验室<飞机>:")
    设 非法实验室 = 造 实验室<飞机>(造 飞机())
} 捕捉 (错误) {
    示("捕获到类实例化约束错误: " & 错误)
}

示("\n测试完成！")
