// Test/10_异常测试.xt
// 测试尝试捕捉 (Try-Catch) 逻辑与 Result 类型包装

示("--- 10_异常测试 开始 ---")

// 1. Result 类型基础 (模拟 FFI 常用返回)
函 模拟除法(a, b) {
    若 b == 0 {
        返 失败("除数不能为零")
    }
    返 成功(a / b)
}

设 结果1 = 模拟除法(10, 2)
若 结果1.成功 {
    示("10 / 2 成功: #{结果1.值}")
}

设 结果2 = 模拟除法(10, 0)
若 非 结果2.成功 {
    示("10 / 0 失败: #{结果2.错误}")
}

// 2. 问号后缀快捷处理
函 计算流程(x) {
    设 v = 模拟除法(x, 2)?
    返 成功(v + 10)
}
示("流程测试: #{计算流程(20).值}") // 预期 20

// 3. 尝试捕捉代码块 (模拟运行时异常捕获)
尝试 {
    示("正在执行危险操作...")
    // 假设这里会抛出一个系统级异常
    // 实际上玄铁目前更多推荐用 Result
    设 无效 = 1 / 0
} 捕捉 (错误) {
    示("捕获到异常: #{错误}")
}

示("--- 10_异常测试 结束 ---")
