// Test/06_OOP进阶测试.xt
// 测试类的继承、方法重写与多态行为

示("--- 06_OOP进阶测试 开始 ---")

型 动物 {
    设 名字
    函 造(名) { 此.名字 = 名 }
    函 叫() { 示("#{此.名字} 在发出声音...") }
}

型 猫 承 动物 {
    函 造(名) { 此.名字 = 名 }
    // 重写方法
    函 叫() { 示("#{此.名字} 在喵喵叫~") }
    函 抓老鼠() { 示("#{此.名字} 抓到了一只老鼠！") }
}

型 狗 承 动物 {
    函 造(名) { 此.名字 = 名 }
    函 叫() { 示("#{此.名字} 在汪汪叫！") }
}

// 1. 基础继承测试
设 a = 造 动物("未知生物")
a.叫()

// 2. 方法重写测试
设 c = 造 猫("小花")
c.叫()
c.抓老鼠()

// 3. 多态测试 (通过数组统一处理)
设 动物们 = [
    造 猫("叮当"),
    造 狗("旺财"),
    造 动物("普通动物")
]

示("多态遍历演示: ")
遍历 动 于 动物们 {
    动.叫() // 预期根据实际类型调用对应方法
}

示("--- 06_OOP进阶测试 结束 ---")
