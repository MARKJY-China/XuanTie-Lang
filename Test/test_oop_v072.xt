型 账户 {
    设 户名 = "访客"
    私 设 余额 = 0
    护 设 级别 = 1
    
    // 构造函数：复用“造”关键字
    函 造(名, 初始存入) {
        户名 = 名
        余额 = 初始存入
        示("账户 [" & 户名 & "] 已创建")
    }
    
    // 原生方法：语义清晰
    函 存款(数额) {
        余额 = 余额 + 数额
        示("存入: " & 数额 & ", 当前余额: " & 余额)
    }
    
    函 获取余额() {
        返 余额
    }
}

// 1. 测试构造函数调用 (造 类型(...))
设 我的账户 = 造 账户("张三", 1000)

// 2. 测试成员访问与赋值 (对象.成员 = 值)
示("户名: " & 我的账户.户名)
我的账户.户名 = "张小三"
示("修改后户名: " & 我的账户.户名)

// 3. 测试私有属性访问控制 (私)
尝试 {
    示("尝试读取余额: " & 我的账户.余额)
} 捕捉 (错误) {
    示("捕获错误 (读取私有): " & 错误)
}

尝试 {
    我的账户.余额 = 99999
} 捕捉 (错误) {
    示("捕获错误 (修改私有): " & 错误)
}

// 4. 测试方法调用与状态同步
我的账户.存款(500)
示("通过方法查询余额: " & 我的账户.获取余额())

// 5. 测试全局具名函数
函 加法(a, b) {
    返 a + b
}
示("全局函数加法(1, 2) = " & 加法(1, 2))
