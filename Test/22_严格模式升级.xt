// Test/22_严格模式升级.xt
// 严格度三档模式 + 警告码升级验证
// 注：此测试通过编译行为验证（需用不同严格度参数编译）

示("--- 22_严格模式升级 开始 ---")

// 场景：弱引用字段缺少可空修饰符——W005
型 测试型 {
    弱 设 字段: 字 = "默认"
    函 造() {}
}
设 t = 造 测试型()
示("默认模式编译通过: #{t.字段}")

// 场景：多否分支——W004
若 真 {
    示("W004测试: 多否分支仍编译通过")
} 否 {
    示("第一个否")
} 否 {
    示("第二个否（被忽略）")
}

示("--- 22_严格模式升级 结束 ---")
