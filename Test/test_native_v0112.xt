// test_native_v0112.xt
示("--- v0.11.2 原生复杂逻辑测试 ---")

// 1. 函数与递归测试
函 斐波那契(n) {
    若 n <= 1 {
        返 n
    }
    返 斐波那契(n - 1) + 斐波那契(n - 2)
}

示("斐波那契(10) 的结果是:")
示(斐波那契(10)) // 应该是 55

// 2. 循环测试 (当)
设 i = 0
设 总和 = 0
当 i <= 100 {
    总和 = 总和 + i
    i = i + 1
}
示("1 到 100 的累加和是:")
示(总和) // 应该是 5050

// 3. 逻辑运算符测试
设 a = 真
设 b = 假

示("逻辑测试:")
若 a 且 非 b {
    示("真 且 非 假 = 真")
}

若 b 或 a {
    示("假 或 真 = 真")
}

// 4. 短路逻辑测试 (通过函数调用确认)
设 计数 = 0
函 增加计数() {
    计数 = 计数 + 1
    返 真
}

若 b 且 增加计数() {
    示("这不应该打印")
}
示("短路 且 后的计数 (应为 0):")
示(计数)

若 a 或 增加计数() {
    示("短路 或 正常")
}
示("短路 或 后的计数 (应为 0):")
示(计数)

示("测试结束")
