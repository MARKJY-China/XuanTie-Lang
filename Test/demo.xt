设 test_features = 引 "./test_features.xt"
设 数学 = 引 "./math_utils.xt"
设 名字 = "玄铁"
设 版本 = 1
//注释内容
示("欢迎使用 " + 名字)

若 版本 > 0 {
    示("版本号大于0")
} 否 {
    示("版本号异常")
}

设 计数 = 1
当 计数 < 4 {
    示("当前计数: " + "点")
    示(计数)
    计数 = 计数 + 1
}

设 加法 = 函(a, b) {
    返 a + b
}

设 结果值 = 加法(10, 20)
示("10 + 20 = " & 结果值)

示("\n数学工具测试")
设 被平方值 = 64
示(" - 初始值：" & 被平方值)
被平方值 = 数学.平方(被平方值)
示(" - 平方后：" & 被平方值)
示(" - 立方后：" & 数学.立方(被平方值))
 
示("\n遍历循环测试")
设 数组A:数组 = [1,2,3,4,5]
设 数组B:数组 = ["A","B","C"]
设 字典A:字典 = {"A":"A1","B":"B1"}
遍历 当前值 于 数组A {
    示(当前值)
    若 当前值 等于 5 {
        示("数组A遍历完成")
    }
}
遍历 当前值 于 数组B {
    示(当前值)
    若 当前值 等于 "C" {
        示("数组B遍历完成")
    }
}
遍历 当前值 于 字典A {
    示(当前值)
    若 当前值 等于 "B1" {
        示("字典A遍历完成")
    }
}