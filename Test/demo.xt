变量 数学 = 引用 "./math_utils.xt"
变量 名字 = "玄铁"
变量 版本 = 1
//注释内容
打印("欢迎使用 " + 名字)

如果 版本 > 0 {
    打印("版本号大于0")
} 否则 {
    打印("版本号异常")
}

变量 计数 = 1
当 计数 < 4 {
    打印("当前计数: " + "点")
    打印(计数)
    计数 = 计数 + 1
}

变量 加法 = 函数(a, b) {
    返回 a + b
}

变量 结果值 = 加法(10, 20)
打印("10 + 20 = " & 结果值)

打印("\n数学工具测试")
变量 被平方值 = 64
打印(" - 初始值：" & 被平方值)
被平方值 = 数学.平方(被平方值)
打印(" - 平方后：" & 被平方值)
打印(" - 立方后：" & 数学.立方(被平方值))
 
打印("\n遍历循环测试")
变量 数组A:数组 = [1,2,3,4,5]
变量 数组B:数组 = ["A","B","C"]
变量 字典A:字典 = {"A":"A1","B":"B1"}
遍历 当前值 于 数组A {
    打印(当前值)
}
遍历 当前值 于 数组B {
    打印(当前值)
}
遍历 当前值 于 字典A {
    打印(当前值)
}