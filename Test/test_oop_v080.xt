型 动物 {
    护 设 种类 = "生物"
    私 设 基因 = "DNA"
    
    函 呼吸() {
        示(种类 & " 正在呼吸...")
    }
}

型 猫 承 动物 {
    函 造(名) {
        种类 = "猫科"
        设 名字 = 名
        示("一只名叫 " & 名字 & " 的小猫出生了")
    }
    
    函 抓老鼠() {
        呼吸() // 调用父类方法
        示("抓到了！基因标记: " & 基因) // 这里应该报错，因为基因是父类的私有属性
    }
    
    函 正确抓老鼠() {
        呼吸()
        示("抓到了！种类是: " & 种类) // 合法，种类是护属性
    }
}

型 账户 {
    私 设 余额 = 100
    函 显示余额() {
        示("当前余额: " & 余额)
    }
}

型 子账户 承 账户 {}

示("--- 继承与保护测试 ---")
设 小橘 = 造 猫("小橘")

示("\n1. 测试继承方法:")
小橘.呼吸()

示("\n2. 测试受保护属性访问控制:")
尝试 {
    示("外部尝试访问种类: " & 小橘.种类)
} 捕捉 (错) {
    示("捕捉到预期错误: " & 错)
}

示("\n3. 测试子类内部访问受保护属性:")
小橘.正确抓老鼠()

示("\n4. 测试子类内部访问父类私有属性:")
尝试 {
    小橘.抓老鼠()
} 捕捉 (错) {
    示("捕捉到预期错误: " & 错)
}

示("\n5. 测试继承自父类的方法访问父类私有属性:")
设 钱包 = 造 子账户()
钱包.显示余额()
