// Test/68_选与通道组合测试.xt
// 测试 选 的正确返回值、超时、多通道竞速（仅 XTC 支持 选）
// GSC 编译此文件会失败（不识别 选），用 `玄铁.exe tie` 编译

示("=== Test 68: 选与通道组合测试 ===")

// 测试1: 基本选——单通道有数据
示("[测试1] 基本选")
设 t1ch = 道(1)
t1ch.发("hello")
设 t1idx = 选([t1ch], 1000)
若 t1idx == 0 { 示("PASS: 测试1 idx=0") } 否 { 示("FAIL: idx=" & t1idx.转字()) }

// 测试2: 选超时
示("[测试2] 选超时")
设 t2ch = 道(1)
设 t2idx = 选([t2ch], 500)
若 t2idx < 0 { 示("PASS: 测试2 超时=-1") } 否 { 示("FAIL: idx=" & t2idx.转字()) }

// 测试3: 多通道竞速
示("[测试3] 多通道竞速")
设 t3fast = 道(1)
设 t3slow = 道(1)
t3slow.发("slow")
t3fast.发("fast")
设 t3idx = 选([t3fast, t3slow], 1000)
若 t3idx == 0 { 示("PASS: 测试3 idx=0") } 否 { 示("FAIL: idx=" & t3idx.转字()) }

// 测试4: 空通道数组单元素
示("[测试4] 单通道选")
设 t4ch = 道(1)
t4ch.发("data")
设 t4r = 选([t4ch], 100)
若 t4r == 0 { 示("PASS: 测试4") } 否 { 示("FAIL: idx=" & t4r.转字()) }

示("=== Test 68 完成 ===")
