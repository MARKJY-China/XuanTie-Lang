示("--- v0.10.0 类型推导与 FFI 增强测试 ---")

// 1. 基础类型推导 (无需显式注解)
设 数字 = 100
设 文本 = "你好，玄铁"
设 是真的 = 真

示("推导出的数字: " & 数字)
示("推导出的文本: " & 文本)

// 2. 泛型类实例化推导
型 盒子<T> {
    设 内容: T
    函 造(物: T) {
        内容 = 物
    }
    函 拿() : T {
        返 内容
    }
}

// 以前需要: 造 盒子<整>(123)
// 现在支持:
设 整数盒 = 造 盒子(123)
设 文本盒 = 造 盒子("秘密")

示("整数盒内容: " & 整数盒.拿())
示("文本盒内容: " & 文本盒.拿())

// 3. 泛型函数调用推导
函 恒等<T>(x: T): T {
    返 x
}

// 以前需要: 恒等<整>(456)
// 现在支持:
设 结果1 = 恒等(456)
设 结果2 = 恒等("自动推导")

示("函数推导结果1: " & 结果1)
示("函数推导结果2: " & 结果2)

// 4. FFI 增强：定义原型
设 库 = 外.加载("user32.dll").值
// 定义 MessageBoxW 原型: (HWND, LPCWSTR, LPCWSTR, UINT) -> int
设 弹窗 = 库.函数("MessageBoxW", [整, 字, 字, 整], 整)

示("已定义外部函数: " & 弹窗)
// 注意：由于是真正的系统调用，我们在非交互环境下不实际执行弹窗以免阻塞测试
// 弹窗(0, "玄铁 v0.10.0 测试", "标题", 0)

示("\n测试完成！")
