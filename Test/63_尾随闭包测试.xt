// Test 63 — 尾随闭包语法糖
// 验证: f(args) 函() { ... } ⟹ f(args, 函() { ... })

示("=== Test 63: 尾随闭包 ===")

// 1. 基础尾随闭包（无参调用）
设 结果1 = ""
函 执行1(闭包) {
    闭包()
}
执行1() 函() {
    结果1 = "PASS: 无参尾随闭包"
}
若 结果1 == "PASS: 无参尾随闭包" { 示("PASS: 无参尾随闭包") } 否 { 示("FAIL: 无参=" & 结果1) }

// 2. 带参数的尾随闭包
设 结果2 = 0
函 执行2(值, 闭包) {
    闭包(值)
}
执行2(42) 函(x) {
    结果2 = x
}
若 结果2 == 42 { 示("PASS: 带参尾随闭包") } 否 { 示("FAIL: 带参=" & 结果2.转字()) }

// 3. 多参数 + 尾随闭包
设 结果3 = ""
函 执行3(前缀, 后缀, 闭包) {
    闭包(前缀 & 后缀)
}
执行3("Hello", "World") 函(合并) {
    结果3 = 合并
}
若 结果3 == "HelloWorld" { 示("PASS: 多参尾随闭包") } 否 { 示("FAIL: 多参=" & 结果3) }

// 4. 嵌套尾随闭包（模拟 UI 声明式写法）
设 结果4 = ""
函 容器(子闭包) {
    结果4 = 结果4 & "[容器"
    子闭包()
    结果4 = 结果4 & "]"
}
函 按钮(子闭包) {
    结果4 = 结果4 & "[按钮"
    子闭包()
    结果4 = 结果4 & "]"
}

容器() 函() {
    按钮() 函() {
        结果4 = 结果4 & "点击"
    }
}
若 结果4 == "[容器[按钮点击]]" { 示("PASS: 嵌套尾随闭包") } 否 { 示("FAIL: 嵌套=" & 结果4) }

// 5. 常规调用 + 尾随闭包（等价性验证）
设 结果5a = ""
设 结果5b = ""
函 等价测试(闭包1, 闭包2) {
    闭包1()
    闭包2()
}

// 尾随闭包写法
等价测试() 函() { 结果5a = "第一" } 函() { 结果5a = 结果5a & "第二" }

// 常规写法
等价测试(函() { 结果5b = "第一" }, 函() { 结果5b = 结果5b & "第二" })

若 结果5a == 结果5b { 示("PASS: 等价性验证") } 否 { 示("FAIL: 等价性=" & 结果5a & " vs " & 结果5b) }

// 6. 仅尾随闭包作为唯一参数（无括号内参数）
设 结果6 = 0
函 仅闭包(闭包) {
    闭包(99)
}
仅闭包() 函(val) {
    结果6 = val
}
若 结果6 == 99 { 示("PASS: 仅尾随闭包") } 否 { 示("FAIL: 仅闭包=" & 结果6.转字()) }

示("=== Test 63 完成 ===")
