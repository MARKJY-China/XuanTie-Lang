// Test/03_集合测试.xt
// 测试数组 (Array) 与 字典 (Dict) 的基础操作

示("--- 03_集合测试 开始 ---")

// 1. 数组测试
设 列表 = [1, 2, 3]
示("初始数组: #{列表}")
列表.追加(4)
示("追加后: #{列表}")
示("数组长度: #{列表.长度}")
示("索引访问 列表[1]: #{列表[1]}")

// 2. 数组遍历
示("遍历数组: ")
遍历 项 于 列表 {
    示(" -> 项: #{项}")
}

// 3. 字典测试
设 映射 = {"名": "玄铁", "版": 0.17}
示("初始字典: #{映射}")
映射["地"] = "中国"
示("修改后: #{映射}")
示("字典大小: #{映射.大小}")

// 4. 字典遍历
示("遍历字典: ")
设 键集 = 映射.键()
遍历 键 于 键集 {
    示(" -> #{键}: #{映射[键]}")
}

// 5. 嵌套集合
设 复杂 = [
    {"id": 1, "值": [10, 20]},
    {"id": 2, "值": [30, 40]}
]
示("复杂嵌套访问: #{复杂[1]["值"][0]}") // 预期 30

示("--- 03_集合测试 结束 ---")
