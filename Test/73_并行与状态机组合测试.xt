// Test/73_并行与状态机组合测试.xt
// 测试 并行 块与状态机的组合：并行内状态机、并行+通道

示("=== Test 73: 并行与状态机组合测试 ===")

// 测试1: 并行纯计算
示("[测试1] 并行纯计算")
设 t1tot = 0
并行 {
    { t1tot = t1tot + 10 }
    { t1tot = t1tot + 20 }
}
若 t1tot == 30 { 示("PASS: 测试1") } 否 { 示("FAIL: tot=" & t1tot.转字()) }

// 测试2: 并行+异步
示("[测试2] 并行+异步")
设 t2val = 0
设 t2inner = 异步 { 时.睡(30); t2val = t2val + 100 }
并行 {
    { 等待(t2inner); t2val = t2val + 1 }
    { t2val = t2val + 2 }
}
若 t2val == 103 { 示("PASS: 测试2") } 否 { 示("FAIL: val=" & t2val.转字()) }

// 测试3: 并行多状态机
示("[测试3] 并行多状态机")
设 t3a = 0
设 t3b = 0
设 t3iA = 异步 { 时.睡(40); t3a = 10 }
设 t3iB = 异步 { 时.睡(20); t3b = 20 }
并行 {
    { 等待(t3iA); t3a = t3a + 1 }
    { 等待(t3iB); t3b = t3b + 1 }
}
若 t3a == 11 且 t3b == 21 { 示("PASS: 测试3") } 否 { 示("FAIL") }

// 测试4: 并行+通道
示("[测试4] 并行+通道")
设 t4ch = 道(2)
并行 {
    { 时.睡(50); t4ch.发("X") }
    { 时.睡(20); t4ch.发("Y") }
}
设 t4ra = t4ch.收()
设 t4rb = t4ch.收()
若 t4ra != 空 且 t4rb != 空 { 示("PASS: 测试4") } 否 { 示("FAIL") }

// 测试5: 4路并行+状态机
示("[测试5] 4路并行")
设 t5sum = 0
设 t5i1 = 异步 { t5sum = t5sum + 1 }
设 t5i2 = 异步 { t5sum = t5sum + 2 }
并行 {
    { 等待(t5i1) }
    { 等待(t5i2) }
    { t5sum = t5sum + 4 }
    { t5sum = t5sum + 8 }
}
若 t5sum == 15 { 示("PASS: 测试5") } 否 { 示("FAIL: sum=" & t5sum.转字()) }

// 测试6: 并行结果收集
示("[测试6] 并行结果")
设 t6a = 0
设 t6b = 0
设 t6inner = 异步 { t6a = 5 }
并行 {
    { 等待(t6inner); t6a = t6a * 2 }
    { t6b = 7 }
}
若 t6a == 10 且 t6b == 7 { 示("PASS: 测试6") } 否 { 示("FAIL: a=" & t6a.转字() & " b=" & t6b.转字()) }

示("=== Test 73 完成 ===")
