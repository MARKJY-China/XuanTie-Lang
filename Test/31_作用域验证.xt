// Test/31_作用域验证.xt
// 验证 设 在 当 体内声明的变量，嵌套 当 条件中是否可见
示("--- 31_作用域验证 ---")

// 测试1: 外层当体内设，内层当条件访问
设 i = 0
当 i < 3 {
    设 j = 0
    当 j < 2 {
        示("i=#{i} j=#{j}")
        j = j + 1
    }
    i = i + 1
}

// 测试2: 遍历内设变量，嵌套当条件访问
设 列表 = [10, 20, 30]
遍历 项 于 列表 {
    设 已处理 = 假
    设 k = 0
    当 k < 2 {
        若 k == 1 { 已处理 = 真 }
        k = k + 1
    }
    示("项=#{项} 已处理=#{已处理}")
}

示("--- 作用域验证结束 ---")
