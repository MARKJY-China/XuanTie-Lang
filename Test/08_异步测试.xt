// Test/08_异步测试.xt
// 测试异步代码块、任务创建与等待

示("--- 08_异步测试 开始 ---")

// 1. 基础异步块
设 x任务1 = 异步 {
    时.睡(500)
    示(" -> [异步] 任务1 执行完毕")
    返 100
}

// 2. 并行执行
示("主线程继续执行...")

// 3. 等待任务结果
设 x结果 = 等待(x任务1)
示("任务1 返回结果: #{结果}")

// 4. 多个异步任务
设 x任务2 = 异步 { 时.睡(200); 返 "A" }
设 x任务3 = 异步 { 时.睡(100); 返 "B" }

示("等待 任务2: #{等待(x任务2)}")
示("等待 任务3: #{等待(x任务3)}")

示("--- 08_异步测试 结束 ---")
