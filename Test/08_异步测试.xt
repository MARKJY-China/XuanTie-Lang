// Test/08_异步测试.xt
// 测试异步代码块、任务创建与等待

示("--- 08_异步测试 开始 ---")

// 1. 基础异步块
设 x任务1 = 异步 {
    时.睡(500)
    示(" -> [异步] 任务1 执行完毕")
}

// 2. 并行执行
示("主线程继续执行...")

// 3. 等待任务结果
设 x结果 = 等待(x任务1)
示("任务1 等待完成")

// 4. 多个异步任务
设 x任务2 = 异步 { 时.睡(2000) }
设 x任务3 = 异步 { 时.睡(1000) } //任务2和任务3是并行开始执行的，所以当等待完任务2就不需要等待任务3了，任务2执行需要2秒，任务3只需1秒。

示("正在等待任务2")
等待(x任务2)
示("任务2 完成")
等待(x任务3)
示("任务3 完成")


示("--- 08_异步测试 结束 ---")
