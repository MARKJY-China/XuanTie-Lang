打印("=== 1. 引用 (模块系统) 测试 ===")
变量 数学工具 = 引用 "math_utils.xt"
打印("4 的平方: " & 数学工具.平方(4))
打印("3 的立方: " & 数学工具.立方(3))

打印("\n=== 2. 数学库测试 ===")
打印("绝对值(-10): " & 数学.绝对值(-10))
打印("绝对值(-3.14): " & 数学.绝对值(-3.14))
打印("平方根(16): " & 数学.平方根(16))
打印("随机数(100): " & 数学.随机数(100))

打印("\n=== 3. 时间库测试 ===")
变量 现在 = 时间.现在()
打印("当前时间戳: " & 现在)
打印("格式化时间: " & 时间.格式化(现在))
打印("自定义格式: " & 时间.格式化(现在, "2006/01/02"))

打印("\n正在休眠 500 毫秒...")
时间.休眠(500)
打印("休眠结束")

打印("\n=== 4. 语法报错增强测试 ===")
