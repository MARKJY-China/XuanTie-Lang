{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "XuanTie",
	"scopeName": "source.xt",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#properties"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#brackets"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.xt",
					"match": "//.*$"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.xt",
					"match": "\\b(若|抑|否|当|循|遍历|于|断|续|返|尝试|捕捉|异步|等待|并行|引|予|接着|且|或|非|是)\\b"
				},
				{
					"name": "storage.type.xt",
					"match": "\\b(设|常|型|函|造|公|私|护|承|口|变量|常量|函数)\\b"
				},
				{
					"name": "support.type.xt",
					"match": "\\b(整|小数|字|逻|空|数组|字典|字节|结果|任务|字符串|整数|逻辑)\\b"
				},
				{
					"name": "support.function.xt",
					"match": "\\b(示|化|解|求|听|连|执|道|成功|失败|打印)\\b"
				},
				{
					"name": "support.class.xt",
					"match": "\\b(文件|网络|字符串|数学|时|系统|外|时间)\\b"
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.xt",
					"match": "([\\p{L}_][\\p{L}\\p{N}_]*)\\s*(?=\\()"
				}
			]
		},
		"properties": {
			"patterns": [
				{
					"name": "variable.other.property.xt",
					"match": "(?<=\\.)(长度|追加|截取|删|插|找|映射|过滤|现|睡|读|写|添|建|拷|移|开|关|头|码|送|收|到字|从字|包含|子串|替换|分割|绝对值|正弦|余弦|平方根|随机数|格式化|参数)\\b"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.other.readwrite.xt",
					"match": "([\\p{L}_][\\p{L}\\p{N}_]*)"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.xt",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.xt",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.double.chinese.xt",
					"begin": "“",
					"end": "”",
					"patterns": [
						{
							"name": "constant.character.escape.xt",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"numbers": {
			"name": "constant.numeric.xt",
			"match": "\\b\\d+(\\.\\d+)?\\b"
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.xt",
					"match": "\\b(真|假|空)\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.xt",
					"match": "="
				},
				{
					"name": "keyword.operator.comparison.xt",
					"match": "(==|!=|<=|>=|<|>|等于)"
				},
				{
					"name": "keyword.operator.arithmetic.xt",
					"match": "(\\+|\\-|\\*|/|%)"
				},
				{
					"name": "keyword.operator.logical.xt",
					"match": "(&|且|或|非|是|\\|)"
				},
				{
					"name": "keyword.operator.other.xt",
					"match": "(\\.|\\?)"
				}
			]
		},
		"brackets": {
			"patterns": [
				{
					"name": "punctuation.bracket.xt",
					"match": "(\\{|\\}|\\[|\\]|\\(|\\))"
				}
			]
		}
	}
}
