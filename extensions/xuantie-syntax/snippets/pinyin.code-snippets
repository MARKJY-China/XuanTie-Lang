{
    "Print": {
        "prefix": ["dy", "dayin"],
        "body": "打印(${1:内容})",
        "description": "打印 (dayin -> 打印)"
    },
    "Variable": {
        "prefix": ["bianliang"],
        "body": "变量 ${1:名字} = ${2:值}",
        "description": "变量 (bianliang -> 变量)"
    },
    "For": {
        "prefix": ["bl", "bianli"],
        "body": [
            "遍历 ${1:元素} 于 ${2:列表} {",
            "\t$0",
            "}"
        ],
        "description": "遍历 (bianli -> 遍历)"
    },
    "Break": {
        "prefix": ["tc", "tiaochu"],
        "body": "跳出",
        "description": "跳出 (tiaochu -> 跳出)"
    },
    "Continue": {
        "prefix": ["jx", "jixu"],
        "body": "继续",
        "description": "继续 (jixu -> 继续)"
    },
    "Constant": {
        "prefix": ["cl", "changl", "changliang"],
        "body": "常量 ${1:名字} = ${2:值}",
        "description": "常量 (changliang -> 常量)"
    },
    "If": {
        "prefix": ["rg", "ruguo"],
        "body": [
            "如果 ${1:条件} {",
            "\t$0",
            "}"
        ],
        "description": "如果 (ruguo -> 如果)"
