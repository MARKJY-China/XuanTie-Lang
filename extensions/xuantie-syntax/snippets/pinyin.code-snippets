            "函数(${1:参数}) {",
            "\t$0",
            "}"
        ],
        "description": "函数 (hanshu -> 函数)"
    },
    "Return": {
        "prefix": ["fh", "fanhui"],
        "body": "返回 $0",
        "description": "返回 (fanhui -> 返回)"
    },
    "True": {
        "prefix": ["z", "zhen"],
        "body": "真",
        "description": "真 (zhen -> 真)"
