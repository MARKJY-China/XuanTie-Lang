E5%80%BC%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Atrue%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22id%22%3A%22AacKr%22%7D"></card><h3 data-lake-id="zlP2h" id="zlP2h"><span data-lake-id="u4b4b5220" id="u4b4b5220">网络</span></h3><ul list="u69c893ff"><li fid="u74e73649" data-lake-id="u4b0c47ee" id="u4b0c47ee"><code data-lake-id="ua990286a" id="ua990286a"><span data-lake-id="u0a43c5c9" id="u0a43c5c9" style="color: #0C68CA">网络</span><span data-lake-id="ud8c0e57a" id="ud8c0e57a">.</span><span data-lake-id="u3a030f10" id="u3a030f10" style="color: #ED740C">获取</span><span data-lake-id="ua881bab6" id="ua881bab6">(URL)</span></code><span data-lake-id="u9065ae7c" id="u9065ae7c">: 返回 </span><code data-lake-id="uddcfea1e" id="uddcfea1e"><span data-lake-id="ufe16b15b" id="ufe16b15b">结果</span></code><span data-lake-id="ue6eda04f" id="ue6eda04f">，包含网页正文内容。支持配合 </span><code data-lake-id="u125a9242" id="u125a9242"><span data-lake-id="u5b87cb0e" id="u5b87cb0e">异步</span></code><span data-lake-id="u39024b74" id="u39024b74"> 使用。</span></li></ul><h3 data-lake-id="diDrh" id="diDrh"><span data-lake-id="ufff1bf4b" id="ufff1bf4b">字符串处理</span></h3><p data-lake-id="uff7553e0" id="uff7553e0"><span data-lake-id="ud6aebc12" id="ud6aebc12">玄铁提供了丰富的字符串处理能力，支持成员方法调用。标识符现在支持以 `?` 结尾，用于返回逻辑值的谓词函数。</span></p><ul list="u18c7364e"><li fid="u34c28ebd" data-lake-id="u122adbeb" id="u122adbeb"><code data-lake-id="ub5010e09" id="ub5010e09"><span data-lake-id="u046fc24c" id="u046fc24c" style="color: #8CCF17">s</span><span data-lake-id="u66184844" id="u66184844">.修剪</span></code><span data-lake-id="u740456cf" id="u740456cf">: 去除首尾空白。</span></li><li fid="u34c28ebd" data-lake-id="u02784771" id="u02784771"><code data-lake-id="ud471c0ad" id="ud471c0ad"><span data-lake-id="u01263fb6" id="u01263fb6" style="color: #74B602">s</span><span data-lake-id="ub88dba02" id="ub88dba02">.长度</span></code><span data-lake-id="uba1e81c8" id="uba1e81c8">：获取字节长度。</span></li><li fid="u34c28ebd" data-lake-id="u460b7a26" id="u460b7a26"><code data-lake-id="u720f8560" id="u720f8560"><span data-lake-id="ue07ef329" id="ue07ef329" style="color: #74B602">s</span><span data-lake-id="u541e3bb7" id="u541e3bb7">.索引(子串)</span></code><span data-lake-id="u5e407223" id="u5e407223">：获取子串第一次出现的位置，未找到返回 -1。</span></li><li fid="u34c28ebd" data-lake-id="u2b6e2feb" id="u2b6e2feb"><code data-lake-id="u1fd2a8f1" id="u1fd2a8f1"><span data-lake-id="u9fd4ccbe" id="u9fd4ccbe" style="color: #74B602">s</span><span data-lake-id="u31c9e23f" id="u31c9e23f">.最后索引(子串)</span></code><span data-lake-id="u2a956c84" id="u2a956c84">：获取子串最后一次出现的位置。</span></li><li fid="u34c28ebd" data-lake-id="u012efb79" id="u012efb79"><code data-lake-id="u1078d79c" id="u1078d79c"><span data-lake-id="u789e7272" id="u789e7272" style="color: #74B602">s</span><span data-lake-id="ueee6e6f6" id="ueee6e6f6">.包含?(子串)</span></code><span data-lake-id="ufa643c7d" id="ufa643c7d">：判断是否包含子串。</span></li><li fid="u34c28ebd" data-lake-id="uf24ce4e1" id="uf24ce4e1"><code data-lake-id="u5b1e068d" id="u5b1e068d"><span data-lake-id="u194a2811" id="u194a2811" style="color: #74B602">s</span><span data-lake-id="uc70330d2" id="uc70330d2">.分割(分隔符)</span></code><span data-lake-id="u95906f18" id="u95906f18">：返回分割后的数组。</span></li><li fid="u34c28ebd" data-lake-id="u360000e7" id="u360000e7"><code data-lake-id="ubc636828" id="ubc636828"><span data-lake-id="ub78041f5" id="ub78041f5" style="color: #74B602">s</span><span data-lake-id="ua94bc89b" id="ua94bc89b">.替换(旧, 新)</span></code><span data-lake-id="u7aeedaad" id="u7aeedaad">：全量替换子串。</span></li><li fid="u34c28ebd" data-lake-id="u8856b152" id="u8856b152"><code data-lake-id="udfa6548a" id="udfa6548a"><span data-lake-id="u6c61eff2" id="u6c61eff2" style="color: #74B602">s</span><span data-lake-id="u1e6d140c" id="u1e6d140c">.大写</span></code><span data-lake-id="u4cc90c5c" id="u4cc90c5c"> / </span><code data-lake-id="u7f3dec7e" id="u7f3dec7e"><span data-lake-id="u93dd9296" id="u93dd9296" style="color: #74B602">s</span><span data-lake-id="u827b5229" id="u827b5229">.小写</span></code><span data-lake-id="u0f8a0ac4" id="u0f8a0ac4">：大小写转换。</span></li><li fid="u34c28ebd" data-lake-id="u37446ea2" id="u37446ea2"><code data-lake-id="u895db28c" id="u895db28c"><span data-lake-id="u84c1d622" id="u84c1d622" style="color: #74B602">s</span><span data-lake-id="u333a1369" id="u333a1369">.修剪</span></code><span data-lake-id="uf028373b" id="uf028373b"> / </span><code data-lake-id="u17e22bfb" id="u17e22bfb"><span data-lake-id="uac226eb3" id="uac226eb3" style="color: #74B602">s</span><span data-lake-id="ud400e832" id="ud400e832">.修剪开头</span></code><span data-lake-id="ub0b15157" id="ub0b15157"> / </span><code data-lake-id="u367ab4bf" id="u367ab4bf"><span data-lake-id="u3cd1d0cb" id="u3cd1d0cb" style="color: #74B602">s</span><span data-lake-id="u42456e1b" id="u42456e1b">.修剪结尾</span></code><span data-lake-id="u614469cb" id="u614469cb">：去除空白或指定前缀/后缀。</span></li><li fid="u34c28ebd" data-lake-id="ud770cb4d" id="ud770cb4d"><code data-lake-id="u6a0aad88" id="u6a0aad88"><span data-lake-id="u3993890c" id="u3993890c" style="color: #74B602">s</span><span data-lake-id="u1f6750a5" id="u1f6750a5">.开头是(x)</span></code><span data-lake-id="u9d1d1f4a" id="u9d1d1f4a"> / </span><code data-lake-id="ufda689c1" id="ufda689c1"><span data-lake-id="u50a31367" id="u50a31367" style="color: #74B602">s</span><span data-lake-id="u2e436529" id="u2e436529">.结尾是(x)</span></code><span data-lake-id="u9f457fca" id="u9f457fca">：前后缀判断。</span></li><li fid="u34c28ebd" data-lake-id="uea6d96ab" id="uea6d96ab"><code data-lake-id="u1295c268" id="u1295c268"><span data-lake-id="u96a58206" id="u96a58206" style="color: #74B602">s</span><span data-lake-id="u2ff4fb03" id="u2ff4fb03">.空?</span></code><span data-lake-id="u11b2ac7c" id="u11b2ac7c"> / </span><code data-lake-id="u66e8acbe" id="u66e8acbe"><span data-lake-id="ued0e0e46" id="ued0e0e46" style="color: #74B602">s</span><span data-lake-id="ud0e84edc" id="ud0e84edc">.非空?</span></code><span data-lake-id="u83a292cf" id="u83a292cf">：判断字符串状态。</span></li><li fid="u34c28ebd" data-lake-id="ua5bacf28" id="ua5bacf28"><code data-lake-id="ubddc433e" id="ubddc433e"><span data-lake-id="u83008ced" id="u83008ced" style="color: #74B602">s</span><span data-lake-id="u8c8a3852" id="u8c8a3852">.重复(次数)</span></code><span data-lake-id="u56676a8f" id="u56676a8f">：重复字符串。</span></li></ul><p data-lake-id="u1ab2733f" id="u1ab2733f"><strong><span data-lake-id="u4faad334" id="u4faad334">字符串模块 (</span></strong><code data-lake-id="u559bbb56" id="u559bbb56"><span data-lake-id="ue2657d41" id="ue2657d41">字符串</span></code><strong><span data-lake-id="u8fdb11f3" id="u8fdb11f3">)</span></strong></p><ul list="uee1f5415"><li fid="u34c28ebd" data-lake-id="u757567a4" id="u757567a4"><code data-lake-id="u4163bd5e" id="u4163bd5e"><span data-lake-id="u8eadd2b1" id="u8eadd2b1" style="color: #0C68CA">字符串</span><strong><span data-lake-id="ucf5b0aa9" id="ucf5b0aa9">.</span></strong><span data-lake-id="u0bac5315" id="u0bac5315" style="color: #ED740C">长度</span><strong><span data-lake-id="u043602eb" id="u043602eb">(</span></strong><span data-lake-id="u9ae0b007" id="u9ae0b007" style="color: #8CCF17">s</span><strong><span data-lake-id="ucd20f062" id="ucd20f062">)</span></strong></code><strong><span data-lake-id="u1cdc8377" id="u1cdc8377">: 获取字节长度。也可直接使用 </span></strong><code data-lake-id="ucd507fff" id="ucd507fff"><span data-lake-id="u2ae3d9a7" id="u2ae3d9a7" style="color: #74B602">s</span><strong><span data-lake-id="u4e72fccf" id="u4e72fccf">.长度</span></strong></code><strong><span data-lake-id="ua768294a" id="ua768294a">。</span></strong></li><li fid="u34c28ebd" data-lake-id="ucb8609c2" id="ucb8609c2"><code data-lake-id="uf4d6dd35" id="uf4d6dd35"><span data-lake-id="ub8980bd4" id="ub8980bd4" style="color: #0C68CA">字符串</span><strong><span data-lake-id="u506d8cbf" id="u506d8cbf">.</span></strong><span data-lake-id="u9f581542" id="u9f581542" style="color: #ED740C">子串</span><strong><span data-lake-id="u3fa33ff3" id="u3fa33ff3">(</span></strong><span data-lake-id="u40e260d2" id="u40e260d2" style="color: #8CCF17">s</span><strong><span data-lake-id="ufc1a6359" id="ufc1a6359">, 起始, 长度)</span></strong></code><strong><span data-lake-id="u4e40805d" id="u4e40805d">: 截取子字符串。</span></strong></li><li fid="u34c28ebd" data-lake-id="u9013100b" id="u9013100b"><code data-lake-id="ueb2fb783" id="ueb2fb783"><span data-lake-id="u6f682326" id="u6f682326" style="color: #0C68CA">字符串</span><strong><span data-lake-id="u941987bc" id="u941987bc">.</span></strong><span data-lake-id="u4a43d34e" id="u4a43d34e" style="color: #ED740C">替换</span><strong><span data-lake-id="ucf13fd19" id="ucf13fd19">(</span></strong><span data-lake-id="u00d19201" id="u00d19201" style="color: #8CCF17">s</span><strong><span data-lake-id="u3951db38" id="u3951db38">, 旧, 新)</span></strong></code><strong><span data-lake-id="u5218388a" id="u5218388a">: 全量替换子串。</span></strong></li><li fid="u34c28ebd" data-lake-id="u5a86bf6b" id="u5a86bf6b"><code data-lake-id="u6c9db62a" id="u6c9db62a"><span data-lake-id="u340deda7" id="u340deda7" style="color: #0C68CA">字符串</span><strong><span data-lake-id="u9442bcfb" id="u9442bcfb">.</span></strong><span data-lake-id="uee6ae8ac" id="uee6ae8ac" style="color: #ED740C">分割</span><strong><span data-lake-id="ueafcd5e3" id="ueafcd5e3">(</span></strong><span data-lake-id="u10b33894" id="u10b33894" style="color: #8CCF17">s</span><strong><span data-lake-id="ua1297fb6" id="ua1297fb6">, 分隔符)</span></strong></code><strong><span data-lake-id="ueb5d5011" id="ueb5d5011">: 返回分割后的数组。</span></strong></li></ul><ul list="ud4785121"><li fid="u013ac697" data-lake-id="u7d691b87" id="u7d691b87"><code data-lake-id="u19bd3194" id="u19bd3194"><span data-lake-id="ud306373b" id="ud306373b" style="color: #117CEE">字符串</span><span data-lake-id="u9cb9ef53" id="u9cb9ef53">.</span><span data-lake-id="u986639e7" id="u986639e7" style="color: #ED740C">连接</span><span data-lake-id="u512092b6" id="u512092b6">(a, b, ...)</span></code><span data-lake-id="u6027eb4a" id="u6027eb4a">：静态拼接多个对象。</span></li><li fid="u013ac697" data-lake-id="ua555a5bf" id="ua555a5bf"><code data-lake-id="udd6fb384" id="udd6fb384"><span data-lake-id="ud82568c9" id="ud82568c9" style="color: #117CEE">字符串</span><span data-lake-id="u9c51cd8d" id="u9c51cd8d">.</span><span data-lake-id="ue0cc58de" id="ue0cc58de" style="color: #ED740C">来自字节</span><span data-lake-id="ua4a53116" id="ua4a53116">(字节)</span></code><span data-lake-id="uc7292d92" id="uc7292d92">：从二进制数据恢复字符串。</span></li></ul><h3 data-lake-id="VU9uP" id="VU9uP"><span data-lake-id="ue9771a9a" id="ue9771a9a">数学运算</span></h3><ul list="uf3e47ccd"><li fid="u55511a57" data-lake-id="uf8c87b8c" id="uf8c87b8c"><code data-lake-id="u7fcc9002" id="u7fcc9002"><span data-lake-id="ud33c379f" id="ud33c379f" style="color: #0C68CA">数学</span><span data-lake-id="u3b6d45ee" id="u3b6d45ee">.</span><span data-lake-id="u523d59b7" id="u523d59b7" style="color: #ED740C">PI</span></code><span data-lake-id="u3b9ca90d" id="u3b9ca90d">, </span><code data-lake-id="u782fa2c7" id="u782fa2c7"><span data-lake-id="ud159cf0b" id="ud159cf0b" style="color: #0C68CA">数学</span><span data-lake-id="u6b773add" id="u6b773add">.</span><span data-lake-id="ud925f86a" id="ud925f86a" style="color: #ED740C">E</span></code><span data-lake-id="ub6d236e2" id="ub6d236e2">: 常量。</span></li><li fid="u55511a57" data-lake-id="ud54af779" id="ud54af779"><code data-lake-id="ucf333b29" id="ucf333b29"><span data-lake-id="ue9719238" id="ue9719238" style="color: #0C68CA">数学</span><span data-lake-id="ub3bd5a9e" id="ub3bd5a9e">.</span><span data-lake-id="uc887d9a4" id="uc887d9a4" style="color: #ED740C">绝对值</span><span data-lake-id="ub2480384" id="ub2480384">(n)</span></code><span data-lake-id="u695a0288" id="u695a0288">: 获取绝对值。</span></li><li fid="u55511a57" data-lake-id="u2b96452e" id="u2b96452e"><code data-lake-id="u33ffea9f" id="u33ffea9f"><span data-lake-id="u06f0b768" id="u06f0b768">数学.</span><span data-lake-id="u517a9185" id="u517a9185" style="color: #ED740C">最大值</span><span data-lake-id="ue35919cb" id="ue35919cb">(...n)</span></code><span data-lake-id="u1357ba28" id="u1357ba28"> / </span><code data-lake-id="u995ac2e5" id="u995ac2e5"><span data-lake-id="u08f7fedb" id="u08f7fedb">数学.</span><span data-lake-id="uc15a52f9" id="uc15a52f9" style="color: #ED740C">最小值</span><span data-lake-id="u2f65bc0f" id="u2f65bc0f">(...n)</span></code><span data-lake-id="ue93039d2" id="ue93039d2">：获取一组数中的最值。</span></li><li fid="u55511a57" data-lake-id="uf03dd83b" id="uf03dd83b"><code data-lake-id="u255a1f16" id="u255a1f16"><span data-lake-id="uab50d30b" id="uab50d30b" style="color: #0C68CA">数学</span><span data-lake-id="uf32aaea9" id="uf32aaea9">.</span><span data-lake-id="ue452b5b7" id="ue452b5b7" style="color: #ED740C">正弦</span><span data-lake-id="u45147432" id="u45147432">(n)</span></code><span data-lake-id="ua144b248" id="ua144b248">, </span><code data-lake-id="u5256c782" id="u5256c782"><span data-lake-id="u8f651f3e" id="u8f651f3e">数学.</span><span data-lake-id="u64245360" id="u64245360" style="color: #ED740C">余弦</span><span data-lake-id="u0a92b96c" id="u0a92b96c">(n)</span></code><span data-lake-id="u778f13dc" id="u778f13dc">: 三角函数。</span></li><li fid="u55511a57" data-lake-id="u8181ce76" id="u8181ce76"><code data-lake-id="u43436850" id="u43436850"><span data-lake-id="u5778b316" id="u5778b316" style="color: #0C68CA">数学</span><span data-lake-id="u2ff11a8c" id="u2ff11a8c">.</span><span data-lake-id="ufd0b810b" id="ufd0b810b" style="color: #ED740C">平方根</span><span data-lake-id="ua6449d62" id="ua6449d62">(n)</span></code><span data-lake-id="uf5dd4d3e" id="uf5dd4d3e">: 计算平方根。</span></li><li fid="u55511a57" data-lake-id="udb7f8d8f" id="udb7f8d8f"><code data-lake-id="ue8df0dd4" id="ue8df0dd4"><span data-lake-id="udb968b6d" id="udb968b6d" style="color: #0C68CA">数学</span><span data-lake-id="ub75eecdb" id="ub75eecdb">.</span><span data-lake-id="uca45fb4e" id="uca45fb4e" style="color: #ED740C">取整</span><span data-lake-id="ub1e0dbef" id="ub1e0dbef">(n)</span></code><span data-lake-id="u25f8b4cf" id="u25f8b4cf">, </span><code data-lake-id="ufa88ab22" id="ufa88ab22"><span data-lake-id="uea6b3ca1" id="uea6b3ca1">数学.</span><span data-lake-id="uf6aea6c1" id="uf6aea6c1" style="color: #ED740C">进一</span><span data-lake-id="ufce59e1c" id="ufce59e1c">(n)</span></code><span data-lake-id="u6f4ba3dc" id="u6f4ba3dc">, </span><code data-lake-id="ub95ca729" id="ub95ca729"><span data-lake-id="u9fa51586" id="u9fa51586">数学.</span><span data-lake-id="uf62a68c9" id="uf62a68c9" style="color: #ED740C">四舍五入</span><span data-lake-id="u1c92bbe2" id="u1c92bbe2">(n)</span></code><span data-lake-id="u50054209" id="u50054209">: 取整函数。</span></li><li fid="u55511a57" data-lake-id="u7614c4f0" id="u7614c4f0"><code data-lake-id="u69ad5c0c" id="u69ad5c0c"><span data-lake-id="u1a3e7c7c" id="u1a3e7c7c" style="color: #0C68CA">数学</span><span data-lake-id="u7adf966b" id="u7adf966b">.</span><span data-lake-id="u33e8dd9f" id="u33e8dd9f" style="color: #ED740C">幂</span><span data-lake-id="u17561777" id="u17561777">(底, 指)</span></code><span data-lake-id="u699731a5" id="u699731a5">: 幂运算。 </span></li><li fid="u55511a57" data-lake-id="u946ac4a9" id="u946ac4a9"><code data-lake-id="u0e115ebf" id="u0e115ebf"><span data-lake-id="u3aa18a33" id="u3aa18a33">数学.</span><span data-lake-id="u34d41a99" id="u34d41a99" style="color: #ED740C">随机</span></code><span data-lake-id="u7f4cb6fa" id="u7f4cb6fa">: 返回 0 到 max 之间的随机整数（默认 max=100）。</span></li><li fid="u55511a57" data-lake-id="ub1a89b20" id="ub1a89b20"><code data-lake-id="u7d054bf0" id="u7d054bf0"><span data-lake-id="ue648da9a" id="ue648da9a" style="color: #0C68CA">数学</span><span data-lake-id="u47bf867a" id="u47bf867a">.</span><span data-lake-id="u8f5db835" id="u8f5db835" style="color: #ED740C">设随机种子</span><span data-lake-id="uedb07747" id="uedb07747">(n)</span></code><span data-lake-id="uf99e5820" id="uf99e5820">: 设置随机数种子。</span></li></ul><h3 data-lake-id="f372E" id="f372E"><span data-lake-id="u9a05563f" id="u9a05563f">时间处理</span></h3><p data-lake-id="uc6240e06" id="uc6240e06"><span data-lake-id="u930d9c42" id="u930d9c42">玄铁推荐使用极简的单字原语 `时` 进行时间操作。</span></p><ul list="u46358f2c"><li fid="u15481545" data-lake-id="uabeaf3fa" id="uabeaf3fa"><code data-lake-id="uc50cf750" id="uc50cf750"><span data-lake-id="u95c3ee57" id="u95c3ee57" style="color: #0C68CA">时</span><span data-lake-id="u7c61c5dd" id="u7c61c5dd">.</span><span data-lake-id="u3f3528cc" id="u3f3528cc" style="color: #ED740C">现</span><span data-lake-id="ue0ef4df4" id="ue0ef4df4">()</span></code><span data-lake-id="u28ebf047" id="u28ebf047">: 获取当前 Unix 时间戳。</span></li><li fid="u15481545" data-lake-id="u9d241d35" id="u9d241d35"><code data-lake-id="u485412ff" id="u485412ff"><span data-lake-id="u9e18b7f2" id="u9e18b7f2" style="color: #0C68CA">时</span><span data-lake-id="u1ad83df9" id="u1ad83df9">.</span><span data-lake-id="u0866eeed" id="u0866eeed" style="color: #ED740C">睡</span><span data-lake-id="u534e4510" id="u534e4510">(ms)</span></code><span data-lake-id="u5776f06f" id="u5776f06f">: 程序暂停指定的毫秒数。</span></li><li fid="u15481545" data-lake-id="u8b65d594" id="u8b65d594"><code data-lake-id="u0aa0906d" id="u0aa0906d"><span data-lake-id="u725d8f40" id="u725d8f40" style="color: #0C68CA">时</span><span data-lake-id="u90482e20" id="u90482e20">.</span><span data-lake-id="u457e3260" id="u457e3260" style="color: #ED740C">解析</span><span data-lake-id="ub23b8e39" id="ub23b8e39">(串, 格式)</span></code><span data-lake-id="ucdcea136" id="ucdcea136">: 字符串转时间戳。</span></li><li fid="u15481545" data-lake-id="u8249b465" id="u8249b465"><code data-lake-id="u9ad2f627" id="u9ad2f627"><span data-lake-id="ucc44885a" id="ucc44885a" style="color: #0C68CA">时</span><span data-lake-id="u023bace0" id="u023bace0">.</span><span data-lake-id="u54cd163e" id="u54cd163e" style="color: #ED740C">格式化</span><span data-lake-id="u8d6e05e5" id="u8d6e05e5">(ts, 格式)</span></code><span data-lake-id="u0a1bc263" id="u0a1bc263">: 将时间戳格式化为字符串。格式遵循 Go 的 layout (如 </span><code data-lake-id="u1c45d54b" id="u1c45d54b"><span data-lake-id="u1423d6df" id="u1423d6df">2006-01-02 15:04:05</span></code><span data-lake-id="u3826a543" id="u3826a543">)。</span></li></ul><h3 data-lake-id="QgqML" id="QgqML"><span data-lake-id="u48f7025b" id="u48f7025b">字节处理 (字节)</span></h3><ul list="u5a7d4dd2"><li fid="u383f2ff7" data-lake-id="u3c78aff0" id="u3c78aff0"><code data-lake-id="u24a1a930" id="u24a1a930"><span data-lake-id="u781bb257" id="u781bb257" style="color: #0C68CA">字节</span><span data-lake-id="uf23ec2e8" id="uf23ec2e8">.</span><span data-lake-id="u9c4d34a8" id="u9c4d34a8" style="color: #ED740C">从字</span><span data-lake-id="udc729f6b" id="udc729f6b">(s)</span></code><span data-lake-id="u9bd19906" id="u9bd19906">: 字符串转字节。</span></li><li fid="u383f2ff7" data-lake-id="u24ecdd6e" id="u24ecdd6e"><code data-lake-id="u92d84841" id="u92d84841"><span data-lake-id="u424efd57" id="u424efd57" style="color: #0C68CA">字节</span><span data-lake-id="u44f8ca07" id="u44f8ca07">.</span><span data-lake-id="ue0671e65" id="ue0671e65" style="color: #ED740C">到字</span><span data-lake-id="u29347cf4" id="u29347cf4">(b)</span></code><span data-lake-id="uccdd848d" id="uccdd848d">: 字节转字符串。</span></li><li fid="u383f2ff7" data-lake-id="u162c1fd1" id="u162c1fd1"><code data-lake-id="u370dd87b" id="u370dd87b"><span data-lake-id="u7a6fe453" id="u7a6fe453" style="color: #0C68CA">字节</span><span data-lake-id="u81eb4c19" id="u81eb4c19">.</span><span data-lake-id="u3fa4c09b" id="u3fa4c09b" style="color: #ED740C">到十六进制</span><span data-lake-id="ud864497d" id="ud864497d">(b)</span></code><span data-lake-id="ua80c4eaa" id="ua80c4eaa">: 转为十六进制字符串。</span></li><li fid="u383f2ff7" data-lake-id="u97cd34da" id="u97cd34da"><code data-lake-id="ue6c61a74" id="ue6c61a74"><span data-lake-id="ud0d315cc" id="ud0d315cc" style="color: #0C68CA">字节</span><span data-lake-id="uee8a48a8" id="uee8a48a8">.</span><span data-lake-id="u6c1d589c" id="u6c1d589c" style="color: #ED740C">相等</span><span data-lake-id="u17af3377" id="u17af3377">(a, b)</span></code><span data-lake-id="u1dbe05d9" id="u1dbe05d9">: 比较两段字节。</span></li><li fid="u383f2ff7" data-lake-id="u40d34063" id="u40d34063"><code data-lake-id="u2a761f05" id="u2a761f05"><span data-lake-id="ub4390a70" id="ub4390a70" style="color: #0C68CA">字节</span><span data-lake-id="u704481fb" id="u704481fb">.</span><span data-lake-id="u2b21fe1d" id="u2b21fe1d" style="color: #ED740C">连接</span><span data-lake-id="u7dc71e08" id="u7dc71e08">(a, b, ...)</span></code><span data-lake-id="u8d484149" id="u8d484149">: 拼接多段字节。</span></li></ul><h3 data-lake-id="gMrz3" id="gMrz3"><span data-lake-id="u0bd26bc3" id="u0bd26bc3">文件与路径 (v0.12.0)</span></h3><ul list="uc327994c"><li fid="u53a50223" data-lake-id="uac67aca7" id="uac67aca7"><strong><span data-lake-id="u2c03e446" id="u2c03e446">文件</span></strong><span data-lake-id="u5e0fc6c5" id="u5e0fc6c5">:</span></li></ul><ul list="uc327994c" data-lake-indent="1"><li fid="ua374cdf6" data-lake-id="uae2303f9" id="uae2303f9"><code data-lake-id="uca4b4f3d" id="uca4b4f3d"><span data-lake-id="uec18c0a8" id="uec18c0a8" style="color: #0C68CA">文件</span><span data-lake-id="u822c0eac" id="u822c0eac">.读(路径)</span></code><span data-lake-id="ua4b38f76" id="ua4b38f76">: 全量读取。</span></li><li fid="ua374cdf6" data-lake-id="u3f3dabda" id="u3f3dabda"><code data-lake-id="u8005d6c6" id="u8005d6c6"><span data-lake-id="ude22685e" id="ude22685e" style="color: #0C68CA">文件</span><span data-lake-id="u369f9218" id="u369f9218">.写(路径, 内容)</span></code><span data-lake-id="ud94eb97f" id="ud94eb97f">: 全量写入。</span></li><li fid="ua374cdf6" data-lake-id="u4f53f50d" id="u4f53f50d"><code data-lake-id="u2229e1b8" id="u2229e1b8"><span data-lake-id="u477fed92" id="u477fed92" style="color: #0C68CA">文件</span><span data-lake-id="u43b586a3" id="u43b586a3">.开(路径)</span></code><span data-lake-id="u497fc3d0" id="u497fc3d0">: 打开句柄。</span></li></ul><ul list="uc327994c" start="2"><li fid="u53a50223" data-lake-id="u66acad2c" id="u66acad2c"><strong><span data-lake-id="u058a0a0d" id="u058a0a0d">路径</span></strong><span data-lake-id="ua46e149f" id="ua46e149f">:</span></li></ul><ul list="uc327994c" data-lake-indent="1"><li fid="u11a4fb5c" data-lake-id="ua572ef13" id="ua572ef13"><code data-lake-id="uaec5fb7a" id="uaec5fb7a"><span data-lake-id="u18e21164" id="u18e21164" style="color: #0C68CA">路径</span><span data-lake-id="u329154f8" id="u329154f8">.合并(a, b, ...)</span></code><span data-lake-id="u10dd95eb" id="u10dd95eb">: 智能合并路径。</span></li><li fid="u11a4fb5c" data-lake-id="u65c800b0" id="u65c800b0"><code data-lake-id="ucebaf015" id="ucebaf015"><span data-lake-id="u2d64d4f5" id="u2d64d4f5" style="color: #0C68CA">路径</span><span data-lake-id="ud49ab4ea" id="ud49ab4ea">.取目录(p)</span></code><span data-lake-id="u8db99fe9" id="u8db99fe9">: 获取父目录。</span></li><li fid="u11a4fb5c" data-lake-id="u3d0f2ea6" id="u3d0f2ea6"><code data-lake-id="u9e69bcb7" id="u9e69bcb7"><span data-lake-id="u9edf029d" id="u9edf029d" style="color: #0C68CA">路径</span><span data-lake-id="ua94077fd" id="ua94077fd">.取文件名(p)</span></code><span data-lake-id="u0f8cb353" id="u0f8cb353">: 获取文件名。</span></li><li fid="u11a4fb5c" data-lake-id="u44d0ea86" id="u44d0ea86"><code data-lake-id="u5ced914b" id="u5ced914b"><span data-lake-id="u10d45485" id="u10d45485" style="color: #0C68CA">路径</span><span data-lake-id="uff9d58a3" id="uff9d58a3">.存在?(p)</span></code><span data-lake-id="uda921036" id="uda921036">: 检查路径是否存在。</span></li></ul><ul list="uc327994c" start="3"><li fid="u53a50223" data-lake-id="u09619348" id="u09619348"><strong><span data-lake-id="u5d4802c3" id="u5d4802c3">目录</span></strong><span data-lake-id="u6adc3f37" id="u6adc3f37">:</span></li></ul><ul list="uc327994c" data-lake-indent="1"><li fid="uc40f00b4" data-lake-id="u12f426c8" id="u12f426c8"><code data-lake-id="u04222650" id="u04222650"><span data-lake-id="u233a2820" id="u233a2820" style="color: #0C68CA">目录</span><span data-lake-id="u6b4409cf" id="u6b4409cf">.建(路径)</span></code><span data-lake-id="u455da6ff" id="u455da6ff">: 递归创建目录。</span></li><li fid="uc40f00b4" data-lake-id="u39e5b52c" id="u39e5b52c"><code data-lake-id="uc7f36e27" id="uc7f36e27"><span data-lake-id="u898f5a06" id="u898f5a06" style="color: #0C68CA">目录</span><span data-lake-id="u1c394938" id="u1c394938">.遍历(路径)</span></code><span data-lake-id="u162b3788" id="u162b3788">: 获取目录下所有文件名。</span></li></ul><h3 data-lake-id="xWnBE" id="xWnBE"><span data-lake-id="ue60f9791" id="ue60f9791">模块化 (v0.3.2)</span></h3><p data-lake-id="uadf1f06a" id="uadf1f06a"><span data-lake-id="u3b04a4b6" id="u3b04a4b6">使用 </span><code data-lake-id="u086a64b0" id="u086a64b0"><span data-lake-id="ua958dfd5" id="ua958dfd5" style="color: #D22D8D">引</span></code><span data-lake-id="u769a0f8e" id="u769a0f8e"> 关键字加载其他脚本，并获得其导出的变量。</span></p><ul list="ub23cbf01"><li fid="u27676d47" data-lake-id="u56ca8509" id="u56ca8509"><strong><span data-lake-id="u0266bdb0" id="u0266bdb0">路径解析</span></strong><span data-lake-id="u25fac3a4" id="u25fac3a4">：相对路径（如 </span><code data-lake-id="u299914e5" id="u299914e5"><span data-lake-id="u183379cb" id="u183379cb">./lib.xt</span></code><span data-lake-id="ua02ee4fa" id="ua02ee4fa">）是相对于</span><strong><span data-lake-id="ua2291e17" id="ua2291e17">当前代码文件</span></strong><span data-lake-id="uaac110b9" id="uaac110b9">所在的目录。这使得你可以轻松地将模块组织到不同的子目录中。</span></li></ul><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22java%22%2C%22code%22%3A%22%E8%AE%BE%20%E5%B7%A5%E5%85%B7%20%3D%20%E5%BC%95%20%5C%22.%2Futils.xt%5C%22%5Cn%E7%A4%BA(%E5%B7%A5%E5%85%B7.%E5%8A%A0%E6%B3%95(1%2C%202))%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Atrue%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22id%22%3A%22zrQS9%22%7D"></card><h3 data-lake-id="tDc7b" id="tDc7b"><span data-lake-id="uabd21dea" id="uabd21dea">编译为二进制 (v0.3.7+)</span></h3><p data-lake-id="u3743dc28" id="u3743dc28"><span data-lake-id="u0b76ce43" id="u0b76ce43">玄铁支持将 </span><code data-lake-id="uf1e52a9f" id="uf1e52a9f"><span data-lake-id="u2ae7922b" id="u2ae7922b">.xt</span></code><span data-lake-id="u18048af4" id="u18048af4"> 脚本直接编译为原生的 </span><code data-lake-id="uba1ea4cd" id="uba1ea4cd"><span data-lake-id="uf4943971" id="uf4943971">.exe</span></code><span data-lake-id="u449f13de" id="u449f13de"> (Windows) 或二进制文件。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22shell%22%2C%22code%22%3A%22xuantie%20build%20%E4%BD%A0%E7%9A%84%E7%A8%8B%E5%BA%8F.xt%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Atrue%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22customStyle%22%3A%5B%7B%22from%22%3A0%2C%22to%22%3A7%2C%22color%22%3A%22%23ECAA04%22%7D%2C%7B%22from%22%3A8%2C%22to%22%3A13%2C%22color%22%3A%22%231DC0C9%22%7D%5D%2C%22id%22%3A%22Wu581%22%7D"></card><ul list="u0f8d0993"><li fid="uddf0cb3f" data-lake-id="ub2fa9b4e" id="ub2fa9b4e"><strong><span data-lake-id="uc7cf4aca" id="uc7cf4aca">优势</span></strong><span data-lake-id="u5f42b764" id="u5f42b764">：执行速度大幅提升，不再依赖玄铁解释器，且源码已转换为机器码。</span></li></ul><card type="block" name="hr" value="data:%7B%22id%22%3A%22ecpKE%22%7D"></card><p data-lake-id="uec822e44" id="uec822e44"><br></p><h2 data-lake-id="cfmqg" id="cfmqg"><span data-lake-id="uf02cbb3a" id="uf02cbb3a">8. 文档与工具</span></h2><h3 data-lake-id="vcbhT" id="vcbhT"><span data-lake-id="u4490beac" id="u4490beac">文档注释 (v0.13.0)</span></h3><p data-lake-id="uc7cde985" id="uc7cde985"><span data-lake-id="ud495188c" id="ud495188c">玄铁支持使用 </span><code data-lake-id="u16e097b7" id="u16e097b7"><span data-lake-id="u213ed8d7" id="u213ed8d7">///</span></code><span data-lake-id="ubc39b8b3" id="ubc39b8b3"> 定义文档注释。紧跟在函数定义前的连续文档注释将被解释器自动收集，并挂载到函数对象上。</span></p><card type="inline" name="codeblock" value="data:%7B%22search%22%3A%22%22%2C%22mode%22%3A%22java%22%2C%22code%22%3A%22%2F%2F%2F%20%E8%BF%99%E6%98%AF%E4%B8%80%E4%B8%AA%E6%BC%94%E7%A4%BA%E5%87%BD%E6%95%B0%5Cn%2F%2F%2F%20%E7%94%A8%E4%BA%8E%E8%AF%B4%E6%98%8E%E6%96%87%E6%A1%A3%E6%B3%A8%E9%87%8A%E7%9A%84%E7%94%A8%E6%B3%95%5Cn%E5%87%BD%20%E6%BC%94%E7%A4%BA()%20%7B%5Cn%20%20%20%20%E8%BF%94%20%E7%9C%9F%5Cn%7D%5Cn%5Cn%E7%A4%BA(%E6%BC%94%E7%A4%BA)%20%2F%2F%20%E6%89%93%E5%8D%B0%E5%87%BD%E6%95%B0%E4%BF%A1%E6%81%AF%E6%97%B6%E4%BC%9A%E5%8C%85%E5%90%AB%E6%96%87%E6%A1%A3%E6%B3%A8%E9%87%8A%22%2C%22autoWrap%22%3Afalse%2C%22lineNumbers%22%3Atrue%2C%22heightLimit%22%3Atrue%2C%22collapsed%22%3Afalse%2C%22hideToolbar%22%3Atrue%2C%22name%22%3A%22%22%2C%22tabSize%22%3Anull%2C%22indentWithTab%22%3Afalse%2C%22lightLines%22%3A%5B%5D%2C%22foldLines%22%3A%5B%5D%2C%22theme%22%3A%22One%20Dark%20Pro%22%2C%22id%22%3A%22qwL5g%22%7D"></card><h3 data-lake-id="IQa0b" id="IQa0b"><span data-lake-id="u6da4d093" id="u6da4d093">标识符命名规范</span></h3><p data-lake-id="u47fdc63e" id="u47fdc63e"><span data-lake-id="ufb7a9c77" id="ufb7a9c77">玄铁的标识符命名非常灵活，除了支持中文外，还允许在末尾使用 </span><code data-lake-id="u6f9d04ae" id="u6f9d04ae"><span data-lake-id="u6bd27a09" id="u6bd27a09">?</span></code><span data-lake-id="u63575e68" id="u63575e68">。</span></p><ul list="u7dbe3e11"><li fid="u886715d5" data-lake-id="u36308d00" id="u36308d00"><strong><span data-lake-id="u06b95e5b" id="u06b95e5b">谓词习惯</span></strong><span data-lake-id="u27c92dbf" id="u27c92dbf">：推荐为返回逻辑值的函数以 </span><code data-lake-id="uf07e6ce3" id="uf07e6ce3"><span data-lake-id="u21c721f9" id="u21c721f9">?</span></code><span data-lake-id="u24699e6c" id="u24699e6c"> 结尾，如 </span><code data-lake-id="u0305a5d8" id="u0305a5d8"><span data-lake-id="u60f7c1a2" id="u60f7c1a2">空?</span></code><span data-lake-id="u8dabf0a1" id="u8dabf0a1">、</span><code data-lake-id="uc6384e73" id="uc6384e73"><span data-lake-id="u913e3f78" id="u913e3f78">存在?</span></code><span data-lake-id="u6a8de901" id="u6a8de901">。</span></li></ul><card type="block" name="hr" value="data:%7B%22id%22%3A%22n2U5H%22%7D"></card><p data-lake-id="uea7b24cd" id="uea7b24cd"><br></p><h2 data-lake-id="sP6sa" id="sP6sa"><span data-lake-id="u0d386aef" id="u0d386aef">9. 支持的转义符</span></h2><ul list="u88a3b4ef"><li fid="u1ba35731" data-lake-id="u8d5b2d69" id="u8d5b2d69"><code data-lake-id="ueaf6a698" id="ueaf6a698"><span data-lake-id="u6025333a" id="u6025333a">\n</span></code><span data-lake-id="u3797b122" id="u3797b122">：换行</span></li><li fid="u1ba35731" data-lake-id="uf1c6fb34" id="uf1c6fb34"><code data-lake-id="u1100d765" id="u1100d765"><span data-lake-id="u5f7d20b3" id="u5f7d20b3">\t</span></code><span data-lake-id="u75d2aeca" id="u75d2aeca">：制表符</span></li><li fid="u1ba35731" data-lake-id="u6de83781" id="u6de83781"><code data-lake-id="u209e5792" id="u209e5792"><span data-lake-id="ua6383ba8" id="ua6383ba8">\r</span></code><span data-lake-id="u18a68a59" id="u18a68a59">：回车</span></li><li fid="u1ba35731" data-lake-id="u38c6761b" id="u38c6761b"><code data-lake-id="ua69e3762" id="ua69e3762"><span data-lake-id="ub49bd061" id="ub49bd061">\b</span></code><span data-lake-id="ufc904bc2" id="ufc904bc2">：退格</span></li><li fid="u1ba35731" data-lake-id="u8c6c5108" id="u8c6c5108"><code data-lake-id="u3387108f" id="u3387108f"><span data-lake-id="u2885c99d" id="u2885c99d">\f</span></code><span data-lake-id="ubbf289b7" id="ubbf289b7">：换页符</span></li><li fid="u1ba35731" data-lake-id="u05670277" id="u05670277"><code data-lake-id="u14e82503" id="u14e82503"><span data-lake-id="u42848196" id="u42848196">\&quot;</span></code><span data-lake-id="u3ab40072" id="u3ab40072">：双引号</span></li><li fid="u1ba35731" data-lake-id="ucefed683" id="ucefed683"><code data-