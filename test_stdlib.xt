// 1. 文件 IO 测试
打印("--- 文件 IO 测试 ---")
变量 文件名:字符串 = "test_io.txt"
变量 内容 = "这是由玄铁编写的内容。\n\t包含换行符和制表符。"

文件.写入(文件名, 内容)
    .接着(函数(结果) {
        打印("成功写入文件: " & 文件名)
        返回 文件.读取(文件名)
    })
    .接着(函数(读取内容) {
        打印("读取到的内容: ")
        打印(读取内容)
        返回 成功(真)
    })
    .否则(函数(错误) {
        打印("文件操作失败: " & 错误)
    })

// 2. 网络请求测试
打印("\n--- 网络请求测试 ---")
变量 任务 = 异步 {
    网络.获取("http://www.baidu.com")
}

打印("正在异步获取网页...")
变量 网页结果 = 等待(任务)

网页结果
    .接着(函数(正文) {
        变量 长度 = 字符串.长度(正文)
        打印("成功获取网页，长度: " & 长度)
        打印("正文第一个字符: " & 正文[0])
        
        变量 wjm = "baidu.com.html"
        文件.写入(wjm, 正文)
            .接着(函数(结果) {
                打印("成功写入文件: " & wjm)
                返回 成功(真)
            })
            .否则(函数(错误) {
                打印("写入文件失败: " & 错误)
            })
        返回 成功(真)
    })
    .否则(函数(错误) {
        打印("获取网页失败: " & 错误)
    })

// 3. 字符串处理测试
打印("\n--- 字符串处理测试 ---")
变量 原文 = "玄铁编程语言，玄铁利刃"
打印("原文: " & 原文)
打印("替换结果: " & 字符串.替换(原文, "玄铁", "XuanTie"))
打印("子串测试: " & 字符串.子串(原文, 0, 6))
打印("分割测试: ")
打印(字符串.分割(原文, "，"))
