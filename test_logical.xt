打印("--- 逻辑运算符测试 ---")

变量 a = 真
变量 b = 假

打印("真 且 假: " & (a 且 b))
打印("真 或 假: " & (a 或 b))
打印("非 真: " & (非 a))
打印("非 假: " & (非 b))

打印("\n--- 组合逻辑测试 ---")
如果 (10 > 5) 且 (3 < 4) {
    打印("10 > 5 且 3 < 4 为真")
}

如果 (10 < 5) 或 (3 < 4) {
    打印("(10 < 5) 或 (3 < 4) 为真")
}

打印("\n--- 短路求值测试 ---")
变量 报错函数 = 函数() {
    打印("错误：短路求值失败，执行了不该执行的代码！")
    返回 1/0
}

如果 假 且 报错函数() {
    打印("这行不应该被打印")
} 否则 {
    打印("假 且 ... 短路成功")
}

如果 真 或 报错函数() {
    打印("真 或 ... 短路成功")
}

打印("\n--- 数值取反测试 ---")
变量 x = 10
打印("x = 10, -x = " & -x)
变量 y = 3.14
打印("y = 3.14, -y = " & -y)
