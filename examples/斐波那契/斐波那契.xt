// 加入Arena内存池进行测试会大幅优化递归性能

外 函 xt_arena_new(大小: 整): 整
外 函 xt_arena_use(池: 整): 整
外 函 xt_arena_destroy(池: 整): 整

设 池 = xt_arena_new(10 * 1024 * 1024)
xt_arena_use(池)

函 斐波那契(n) {
    若 n <= 1 { 返 n }
    返 斐波那契(n - 1) + 斐波那契(n - 2)
}

设 递归开始 = 时.微秒()
设 递归值 = 斐波那契(30)
设 递归耗时 = 时.微秒() - 递归开始
示("\n[递归性能测试]")
示("-> 斐波那契(30) = #{递归值}, 耗时: #{递归耗时} 微秒")

xt_arena_destroy(池)
示("\n[内存池已销毁]")
